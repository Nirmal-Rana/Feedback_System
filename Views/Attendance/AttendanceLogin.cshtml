@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance Admin Login</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: linear-gradient(135deg, #667eea, #764ba2);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .card {
                background: white;
                border-radius: 22px;
                width: 100%;
                max-width: 400px;
                overflow: hidden;
                box-shadow: 0 24px 64px rgba(0,0,0,0.28);
            }

            .card-header {
                background: linear-gradient(135deg, #667eea, #764ba2);
                padding: 36px 30px;
                text-align: center;
                color: white;
            }

                .card-header i {
                    font-size: 2.4rem;
                    margin-bottom: 12px;
                    display: block;
                }

                .card-header h1 {
                    font-size: 1.3rem;
                    margin-bottom: 5px;
                }

                .card-header p {
                    opacity: 0.82;
                    font-size: 0.86rem;
                }

            .card-body {
                padding: 28px 30px;
            }

            .error-alert {
                background: #fff5f5;
                border-left: 4px solid #ef4444;
                border-radius: 8px;
                padding: 12px 14px;
                margin-bottom: 18px;
                font-size: 0.85rem;
                color: #b91c1c;
            }

            .field {
                margin-bottom: 16px;
            }

                .field label {
                    display: block;
                    font-size: 0.73rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.6px;
                    color: #64748b;
                    margin-bottom: 6px;
                }

            .inp {
                position: relative;
            }

                .inp i {
                    position: absolute;
                    left: 12px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #cbd5e1;
                    font-size: 0.84rem;
                }

                .inp input {
                    width: 100%;
                    padding: 12px 12px 12px 38px;
                    border: 1.5px solid #e2e8f0;
                    border-radius: 10px;
                    font-family: inherit;
                    font-size: 0.9rem;
                    background: #f8fafc;
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s;
                }

                    .inp input:focus {
                        border-color: #667eea;
                        background: white;
                        box-shadow: 0 0 0 3px rgba(102,126,234,0.12);
                    }

            .btn-login {
                width: 100%;
                padding: 14px;
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
                border: none;
                border-radius: 12px;
                font-size: 0.98rem;
                font-weight: 700;
                cursor: pointer;
                transition: opacity 0.2s;
                margin-top: 4px;
            }

                .btn-login:hover {
                    opacity: 0.88;
                }

            .hint {
                margin-top: 16px;
                text-align: center;
                font-size: 0.8rem;
                color: #aaa;
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header">
            <i class="fas fa-user-shield"></i>
            <h1>Attendance Admin</h1>
            <p>Texas College of Management & IT</p>
        </div>
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="error-alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    @ViewBag.Error
                </div>
            }

            @* ✅ FIXED: Added asp-controller explicitly *@
            <form method="post"
                  asp-controller="Attendance"
                  asp-action="AttendanceLogin">
                @Html.AntiForgeryToken()
                <div class="field">
                    <label>Username</label>
                    <div class="inp">
                        <i class="fas fa-user"></i>
                        <input type="text"
                               name="username"
                               placeholder="Enter username"
                               required
                               autocomplete="off"
                               spellcheck="false" />
                    </div>
                </div>
                <div class="field">
                    <label>Password</label>
                    <div class="inp">
                        <i class="fas fa-lock"></i>
                        <input type="password"
                               name="password"
                               placeholder="Enter password"
                               required
                               autocomplete="off" />
                    </div>
                </div>
                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i> Login
                </button>
            </form>

            <p class="hint">
                Username: attendance &nbsp;|&nbsp; Password: Texas@2026
            </p>
        </div>
    </div>
</body>
</html>