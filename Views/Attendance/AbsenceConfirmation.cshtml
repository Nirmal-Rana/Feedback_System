@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Absence Reported</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: linear-gradient(135deg, #667eea, #764ba2);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .card {
                background: white;
                border-radius: 22px;
                max-width: 420px;
                width: 100%;
                padding: 40px 30px;
                text-align: center;
                box-shadow: 0 24px 64px rgba(0,0,0,0.28);
            }

            .check-circle {
                width: 80px;
                height: 80px;
                background: linear-gradient(135deg, #43e97b, #38f9d7);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
                font-size: 2rem;
                color: white;
                animation: pop 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
            }

            @@keyframes pop {
                from {
                    transform: scale(0);
                }

                to {
                    transform: scale(1);
                }
            }

            h1 {
                font-size: 1.4rem;
                color: #1a1a2e;
                margin-bottom: 10px;
            }

            p {
                color: #64748b;
                font-size: 0.9rem;
                line-height: 1.6;
            }

            .ref-box {
                background: #f8fafc;
                border: 2px dashed #667eea;
                border-radius: 12px;
                padding: 14px 20px;
                margin: 20px 0;
            }

                .ref-box .lbl {
                    font-size: 0.72rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    color: #888;
                }

                .ref-box .num {
                    font-size: 1.6rem;
                    font-weight: 800;
                    color: #667eea;
                }

            .btn-home {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 12px 28px;
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
                border-radius: 12px;
                text-decoration: none;
                font-weight: 700;
                font-size: 0.92rem;
                margin-top: 10px;
                transition: opacity 0.2s;
            }

                .btn-home:hover {
                    opacity: 0.88;
                    color: white;
                }
    </style>
</head>
<body>
    <div class="card">
        <div class="check-circle">
            <i class="fas fa-check"></i>
        </div>
        <h1>Absence Reported!</h1>
        <p>
            Your absence has been recorded successfully.<br />
            The admin has been notified.
        </p>
        <div class="ref-box">
            <div class="lbl">Reference ID</div>
            <div class="num">#@TempData["AbsenceId"]</div>
        </div>
        <p style="font-size:0.82rem; color:#999;">
            Reported by <strong>@TempData["AbsenceName"]</strong>
        </p>
        <a href="/" class="btn-home">
            <i class="fas fa-home"></i> Back to Home
        </a>
    </div>
</body>
</html>