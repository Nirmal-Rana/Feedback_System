@model CollegeIssueManagement.Models.ViewModels.BaseIssueViewModel
@using CollegeIssueManagement.Models.ViewModels

@{
    ViewData["Title"] = $"Submit {ViewBag.IssueType} Issue";
    var issueType = ViewBag.IssueType as string;

    var typeConfig = issueType switch
    {
        "Internet" => (Icon: "fa-wifi", Color: "#667eea", Light: "#f0f0ff", Label: "Internet Issue"),
        "IDCard" => (Icon: "fa-id-card", Color: "#667eea", Light: "#f0f0ff", Label: "ID Card Issue"),
        "Internship" => (Icon: "fa-briefcase", Color: "#667eea", Light: "#f0f0ff", Label: "Internship Apply"),
        "JobOpportunity" => (Icon: "fa-building", Color: "#667eea", Light: "#f0f0ff", Label: "Job Opportunity"),
        "FacultyFeedback" => (Icon: "fa-chalkboard-teacher", Color: "#667eea", Light: "#f0f0ff", Label: "Faculty Feedback"),
        "Counselling" => (Icon: "fa-hands-helping", Color: "#667eea", Light: "#f0f0ff", Label: "Counselling"),
        "ManagementAttention" => (Icon: "fa-bullhorn", Color: "#667eea", Light: "#f0f0ff", Label: "Management Attention"),
        _ => (Icon: "fa-file-alt", Color: "#667eea", Light: "#f0f0ff", Label: "General Issue")
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@@9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            :root {
                --accent: @typeConfig.Color;
                --accent-light: @typeConfig.Light;
                --text-dark: #0f172a;
                --text-muted: #64748b;
                --border: #e2e8f0;
                --bg: #f1f5f9;
                --white: #ffffff;
                --radius: 14px;
                --radius-sm: 9px;
            }

            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html, body {
                min-height: 100%;
                font-family: 'DM Sans', sans-serif;
                background: var(--bg);
                color: var(--text-dark);
            }

            .top-nav {
                background: var(--accent);
                padding: 0 32px;
                height: 58px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 100;
                box-shadow: 0 2px 12px rgba(102,126,234,0.25);
            }

            .top-nav-left {
                display: flex;
                align-items: center;
                gap: 12px;
                color: white;
            }

                .top-nav-left .nav-icon {
                    width: 34px;
                    height: 34px;
                    background: rgba(255,255,255,0.18);
                    border-radius: 9px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 0.9rem;
                }

                .top-nav-left .nav-title {
                    font-weight: 700;
                    font-size: 0.95rem;
                }

                .top-nav-left .nav-subtitle {
                    font-size: 0.75rem;
                    opacity: 0.7;
                }

            .top-nav-back {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                color: rgba(255,255,255,0.85);
                text-decoration: none;
                font-size: 0.84rem;
                font-weight: 600;
                padding: 7px 14px;
                background: rgba(255,255,255,0.14);
                border: 1px solid rgba(255,255,255,0.25);
                border-radius: 8px;
                transition: all 0.2s;
            }

                .top-nav-back:hover {
                    background: rgba(255,255,255,0.24);
                    color: white;
                    text-decoration: none;
                }

            .progress-bar-wrap {
                background: white;
                border-bottom: 1px solid var(--border);
                padding: 12px 32px;
            }

            .progress-steps {
                display: flex;
                align-items: center;
                max-width: 600px;
                margin: 0 auto;
            }

            .p-step {
                display: flex;
                align-items: center;
                gap: 8px;
                flex: 1;
            }

                .p-step:last-child {
                    flex: none;
                }

            .p-dot {
                width: 26px;
                height: 26px;
                border-radius: 50%;
                border: 2px solid #e2e8f0;
                background: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.68rem;
                font-weight: 700;
                color: #aaa;
                flex-shrink: 0;
                transition: all 0.3s;
            }

                .p-dot.is-active {
                    background: var(--accent);
                    border-color: var(--accent);
                    color: white;
                    box-shadow: 0 0 0 4px rgba(102,126,234,0.15);
                }

                .p-dot.is-done {
                    background: #22c55e;
                    border-color: #22c55e;
                    color: white;
                }

            .p-label {
                font-size: 0.74rem;
                font-weight: 600;
                color: #aaa;
                white-space: nowrap;
                transition: color 0.3s;
            }

                .p-label.is-active {
                    color: var(--accent);
                }

                .p-label.is-done {
                    color: #22c55e;
                }

            .p-line {
                flex: 1;
                height: 2px;
                background: #e2e8f0;
                margin: 0 10px;
                border-radius: 2px;
                transition: background 0.3s;
            }

                .p-line.is-done {
                    background: #22c55e;
                }

            .form-area {
                max-width: 820px;
                margin: 0 auto;
                padding: 32px 24px 64px;
            }

            .form-topbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 24px;
                flex-wrap: wrap;
                gap: 12px;
            }

                .form-topbar h1 {
                    font-family: 'DM Serif Display', serif;
                    font-size: 1.55rem;
                    color: var(--text-dark);
                    line-height: 1.2;
                }

                    .form-topbar h1 em {
                        font-style: normal;
                        color: var(--accent);
                    }

            .required-pill {
                font-size: 0.75rem;
                font-weight: 600;
                color: var(--text-muted);
                background: var(--white);
                border: 1px solid var(--border);
                padding: 5px 12px;
                border-radius: 20px;
                white-space: nowrap;
            }

            .error-box {
                background: #fff5f5;
                border: 1px solid #fecaca;
                border-left: 4px solid #ef4444;
                border-radius: var(--radius-sm);
                padding: 13px 16px;
                margin-bottom: 24px;
                font-size: 0.86rem;
                color: #b91c1c;
            }

            .form-section {
                background: var(--white);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 26px 28px;
                margin-bottom: 16px;
            }

            .section-head {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 22px;
                padding-bottom: 16px;
                border-bottom: 1px solid #f1f5f9;
            }

            .section-head-icon {
                width: 36px;
                height: 36px;
                background: var(--accent-light);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.88rem;
                color: var(--accent);
                flex-shrink: 0;
            }

            .section-head-text h2 {
                font-size: 0.82rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                color: var(--text-dark);
            }

            .section-head-text p {
                font-size: 0.75rem;
                color: var(--text-muted);
                margin-top: 2px;
            }

            .fields-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 16px;
            }

            .f-full {
                grid-column: 1 / -1;
            }

            .field {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

                .field label {
                    font-size: 0.75rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    color: var(--text-muted);
                }

                    .field label .req {
                        color: #ef4444;
                        margin-left: 2px;
                    }

            .input-box {
                position: relative;
            }

                .input-box .ico {
                    position: absolute;
                    left: 12px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #cbd5e1;
                    font-size: 0.82rem;
                    pointer-events: none;
                    transition: color 0.2s;
                }

                .input-box:focus-within .ico {
                    color: var(--accent);
                }

                .input-box input,
                .input-box select,
                .input-box textarea {
                    width: 100%;
                    padding: 10px 12px 10px 36px;
                    background: #f8fafc;
                    border: 1.5px solid #e2e8f0;
                    border-radius: var(--radius-sm);
                    font-family: 'DM Sans', sans-serif;
                    font-size: 0.9rem;
                    color: var(--text-dark);
                    outline: none;
                    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
                    appearance: none;
                    -webkit-appearance: none;
                }

                    .input-box input::placeholder,
                    .input-box textarea::placeholder {
                        color: #94a3b8;
                    }

                    .input-box input:focus,
                    .input-box select:focus,
                    .input-box textarea:focus {
                        border-color: var(--accent);
                        background: white;
                        box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
                    }

                .input-box.no-ico input,
                .input-box.no-ico select,
                .input-box.no-ico textarea {
                    padding-left: 12px;
                }

                .input-box.sel-box::after {
                    content: '\f107';
                    font-family: 'Font Awesome 6 Free';
                    font-weight: 900;
                    position: absolute;
                    right: 12px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    pointer-events: none;
                    font-size: 0.78rem;
                }

                .input-box textarea {
                    resize: vertical;
                    min-height: 92px;
                    line-height: 1.55;
                }

            .field-error {
                font-size: 0.74rem;
                color: #ef4444;
                display: flex;
                align-items: center;
                gap: 4px;
            }

            .checkbox-label {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                cursor: pointer;
                font-size: 0.88rem;
                font-weight: 600;
                color: var(--text-dark);
                user-select: none;
                padding: 10px 14px;
                background: #f8fafc;
                border: 1.5px solid var(--border);
                border-radius: 10px;
                transition: all 0.2s;
            }

                .checkbox-label:hover {
                    border-color: var(--accent);
                    background: var(--accent-light);
                }

                .checkbox-label input.custom-check {
                    display: none;
                }

            .check-box {
                width: 18px;
                height: 18px;
                border: 2px solid #cbd5e1;
                border-radius: 5px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                transition: all 0.2s;
                background: white;
            }

            .checkbox-label:has(input:checked) .check-box {
                background: var(--accent);
                border-color: var(--accent);
            }

                .checkbox-label:has(input:checked) .check-box::after {
                    content: '✓';
                    color: white;
                    font-size: 0.72rem;
                    font-weight: 800;
                }

            .checkbox-label:has(input:checked) {
                border-color: var(--accent);
                background: var(--accent-light);
            }

            .submit-bar {
                background: var(--white);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 22px 28px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 20px;
            }

            .submit-note {
                font-size: 0.82rem;
                color: var(--text-muted);
                line-height: 1.55;
            }

                .submit-note strong {
                    color: var(--text-dark);
                    font-weight: 700;
                }

            .btn-submit {
                display: inline-flex;
                align-items: center;
                gap: 9px;
                padding: 12px 28px;
                background: var(--accent);
                color: white;
                border: none;
                border-radius: 10px;
                font-family: 'DM Sans', sans-serif;
                font-size: 0.92rem;
                font-weight: 700;
                cursor: pointer;
                white-space: nowrap;
                flex-shrink: 0;
                transition: all 0.25s ease;
                box-shadow: 0 4px 14px rgba(102,126,234,0.3);
            }

                .btn-submit:hover {
                    filter: brightness(1.08);
                    transform: translateY(-2px);
                    box-shadow: 0 8px 22px rgba(102,126,234,0.38);
                }

                .btn-submit:active {
                    transform: translateY(0);
                }

                .btn-submit:disabled {
                    opacity: 0.7;
                    cursor: not-allowed;
                    transform: none;
                    filter: none;
                }

            @@media (max-width: 640px) {
                .top-nav {
                    padding: 0 16px;
                }

                .form-area {
                    padding: 20px 16px 48px;
                }

                .fields-grid {
                    grid-template-columns: 1fr;
                }

                .submit-bar {
                    flex-direction: column;
                    align-items: stretch;
                }

                .btn-submit {
                    justify-content: center;
                }

                .progress-bar-wrap {
                    padding: 10px 16px;
                }

                .p-label {
                    display: none;
                }
            }
    </style>
</head>
<body>

    <nav class="top-nav">
        <div class="top-nav-left">
            <div class="nav-icon">
                <i class="fas @typeConfig.Icon"></i>
            </div>
            <div>
                <div class="nav-title">@typeConfig.Label</div>
                <div class="nav-subtitle">Texas College of Management & IT</div>
            </div>
        </div>
        <a href="/" class="top-nav-back">
            <i class="fas fa-arrow-left"></i> Back to Home
        </a>
    </nav>

    <div class="progress-bar-wrap">
        <div class="progress-steps">
            <div class="p-dot is-active" id="dot1">1</div>
            <span class="p-label is-active" id="lbl1">Personal Info</span>
            <div class="p-line" id="line1"></div>
            <div class="p-dot" id="dot2">2</div>
            <span class="p-label" id="lbl2">Issue Details</span>
            <div class="p-line" id="line2"></div>
            <div class="p-dot" id="dot3">3</div>
            <span class="p-label" id="lbl3">Submit</span>
        </div>
    </div>

    <div class="form-area">
        <div class="form-topbar">
            <h1>New <em>@typeConfig.Label</em></h1>
            <span class="required-pill">
                <i class="fas fa-asterisk" style="font-size:0.55rem;margin-right:4px;"></i>
                Required fields
            </span>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-box">
                <i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i>
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form asp-action="CreateIssue" method="post" enctype="multipart/form-data" id="issueForm" novalidate>
            <input type="hidden" name="issueType" value="@issueType" />

            @* Section 1 — Personal Info *@
            <div class="form-section" id="section1">
                <div class="section-head">
                    <div class="section-head-icon"><i class="fas fa-user"></i></div>
                    <div class="section-head-text">
                        <h2>Personal Information</h2>
                        <p>Your basic student details</p>
                    </div>
                </div>
                <div class="fields-grid">
                    <div class="field">
                        <label asp-for="StudentName">Full Name <span class="req">*</span></label>
                        <div class="input-box">
                            <i class="fas fa-user ico"></i>
                            <input asp-for="StudentName" placeholder="e.g. Aarav Sharma" required />
                        </div>
                        <span asp-validation-for="StudentName" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="StudentRollNo">LCID <span class="req">*</span></label>
                        <div class="input-box">
                            <i class="fas fa-hashtag ico"></i>
                            <input asp-for="StudentRollNo" placeholder="e.g. LC001700...." required />
                        </div>
                        <span asp-validation-for="StudentRollNo" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="StudentEmail">Email Address <span class="req">*</span></label>
                        <div class="input-box">
                            <i class="fas fa-envelope ico"></i>
                            <input asp-for="StudentEmail" type="email" placeholder="you@college.edu.np" required />
                        </div>
                        <span asp-validation-for="StudentEmail" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="StudentPhone">Phone Number <span class="req">*</span></label>
                        <div class="input-box">
                            <i class="fas fa-phone ico"></i>
                            <input asp-for="StudentPhone" type="tel" placeholder="98XXXXXXXX" required />
                        </div>
                        <span asp-validation-for="StudentPhone" class="field-error"></span>
                    </div>
                    <div class="field f-full">
                        <label asp-for="StudentDepartment">Department <span class="req">*</span></label>
                        <div class="input-box no-ico sel-box">
                            <select asp-for="StudentDepartment" id="deptSelect" required>
                                <option value="">Select your department</option>
                                <option value="BIT — Bachelor of Information Technology">BIT — Bachelor of Information Technology</option>
                                <option value="BCA — Bachelor of Computer Applications">BCA — Bachelor of Computer Applications</option>
                                <option value="BBS — Bachelor of Business Studies">BBS — Bachelor of Business Studies</option>
                                <option value="BBA — Bachelor of Business Administration">BBA — Bachelor of Business Administration</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <span asp-validation-for="StudentDepartment" class="field-error"></span>
                    </div>
                </div>
            </div>

            @* Section 2 — Dynamic Contextual Details Section *@
            <div class="form-section" id="section2">
                <div class="section-head">
                    <div class="section-head-icon"><i class="fas @typeConfig.Icon"></i></div>
                    <div class="section-head-text">
                        <h2> Details</h2>
                        <p>Specific information about your @issueType issue</p>
                    </div>
                </div>

                @if (issueType == "Internship")
                {
                    @await Html.PartialAsync("~/Views/Home/IssueForms/_InternshipForm.cshtml", Model as InternshipIssueViewModel)
                }
                else
                {
                    <div class="field f-full">
                        <label asp-for="Description">Issue Description <span class="req">*</span></label>
                        <div class="input-box no-ico">
                            <textarea asp-for="Description" rows="5" placeholder="Describe your issue clearly..." required></textarea>
                        </div>
                        <span asp-validation-for="Description" class="field-error"></span>
                    </div>
                    <input type="hidden" asp-for="Type" value="@issueType" />
                }
            </div>

            @* Form Submission Bar *@
            <div class="submit-bar">
                
                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="fas fa-paper-plane"></i>
                    <span id="submitTxt">Submit</span>
                    <i class="fas fa-spinner fa-spin" id="submitSpin" style="display:none;"></i>
                </button>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    <script>
        const dot1 = document.getElementById('dot1');
        const dot2 = document.getElementById('dot2');
        const dot3 = document.getElementById('dot3');
        const lbl1 = document.getElementById('lbl1');
        const lbl2 = document.getElementById('lbl2');
        const lbl3 = document.getElementById('lbl3');
        const line1 = document.getElementById('line1');
        const line2 = document.getElementById('line2');

        function markDone(dot, lbl, line) {
        dot.classList.remove('is-active');
        dot.classList.add('is-done');
        dot.innerHTML = '<i class="fas fa-check" style="font-size:0.58rem;"></i>';
        if (lbl) { lbl.classList.remove('is-active'); lbl.classList.add('is-done'); }
        if (line) { line.classList.add('is-done'); }
        }

        function setActive(dot, lbl) {
        dot.classList.add('is-active');
        if (lbl) lbl.classList.add('is-active');
        }

        const sec2 = document.getElementById('section2');
        if (sec2) {
        new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
        markDone(dot1, lbl1, line1);
        setActive(dot2, lbl2);
        }
        }, { threshold: 0.1 }).observe(sec2);
        }

        document.getElementById('issueForm').addEventListener('submit', function (e) {
        if (!$(this).valid()) {
        e.preventDefault();
        return;
        }

        markDone(dot2, lbl2, line2);
        setActive(dot3, lbl3);

        const btn = document.getElementById('submitBtn');
        const txt = document.getElementById('submitTxt');
        const spin = document.getElementById('submitSpin');

        btn.disabled = true;
        txt.textContent = 'Submitting…';
        spin.style.display = 'inline-block';
        });

        // Safe Session Restore (Skips file parameters safely)
        const fields = document.querySelectorAll('input:not([type=hidden]):not([type=file]), select, textarea');

        function save() {
        const d = {};
        fields.forEach(f => { if (f.name) d[f.name] = f.value; });
        sessionStorage.setItem('iform_@issueType', JSON.stringify(d));
        }

        function restore() {
        const raw = sessionStorage.getItem('iform_@issueType');
        if (!raw) return;
        const d = JSON.parse(raw);
        fields.forEach(f => { if (f.name && d[f.name] !== undefined) f.value = d[f.name]; });
        }

        fields.forEach(f => f.addEventListener('input', save));
        restore();
    </script>
</body>
</html>