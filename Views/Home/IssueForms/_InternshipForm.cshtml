@model CollegeIssueManagement.Models.ViewModels.InternshipIssueViewModel

<div class="fields-grid">

    <div class="field">
        <label>Current Semester <span class="req">*</span></label>
        <div class="input-box no-ico sel-box">
            <select asp-for="CurrentSemester" required>
                <option value="">Select semester</option>
                @for (int i = 1; i <= 8; i++)
                {
                    <option value="@i">Semester @i</option>
                }
            </select>
        </div>
        <span asp-validation-for="CurrentSemester" class="field-error"></span>
    </div>

    <div class="field">
        <label>Preferred Field / Domain <span class="req">*</span></label>
        <div class="input-box no-ico sel-box">
            <select asp-for="PreferredField" id="preferredFieldSelect" required>
                <option value="">Select field</option>
                <option value="Web Development">Web Development</option>
                <option value="Mobile Development">Mobile Development</option>
                <option value="Data Science / AI">Data Science / AI</option>
                <option value="Networking / IT Support">Networking / IT Support</option>
                <option value="Cybersecurity">Cybersecurity</option>
                <option value="UI/UX Design">UI/UX Design</option>
                <option value="Other">Other (Specify below)</option>
            </select>
        </div>
        <span asp-validation-for="PreferredField" class="field-error"></span>
    </div>

    <div class="field" id="customPreferredFieldWrap" style="display:none;">
        <label>Specify Preferred Field <span class="req">*</span></label>
        <div class="input-box">
            <i class="fas fa-edit ico"></i>
            <input type="text" id="customPreferredFieldInput" placeholder="e.g. Game Development, Cloud Computing..." />
        </div>
    </div>

    <div class="field">
        <label>Preferred Duration</label>
        <div class="input-box no-ico sel-box">
            <select asp-for="PreferredDuration">
                <option value="">Select duration</option>
                <option>1 Month</option>
                <option>2 Months</option>
                <option>3 Months</option>
                <option>6 Months</option>
            </select>
        </div>
        <span asp-validation-for="PreferredDuration" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label>Upload Curriculum Vitae (CV) <span class="req">*</span></label>
        <div class="input-box">
            <i class="fas fa-file-upload ico"></i>
            <input type="file" asp-for="CVFile" accept=".pdf,.doc,.docx" required
                   style="padding-top: 10px; cursor: pointer;" />
        </div>
        <span style="font-size:0.75rem; color:#888; margin-top:4px; display:block;">
            Supported formats: PDF, DOC, DOCX (Max size: 5MB)
        </span>
        <span asp-validation-for="CVFile" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label>Skills You Have</label>
        <div class="input-box no-ico">
            <textarea asp-for="Skills" rows="3"
                      placeholder="e.g. C#, ASP.NET, SQL, React..."></textarea>
        </div>
        <span asp-validation-for="Skills" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label class="checkbox-label">
            <input asp-for="HasPreviousExperience" type="checkbox"
                   id="hasPrevExp" class="custom-check" />
            <span class="check-box"></span>
            Do you have previous internship experience?
        </label>
    </div>

    <div class="field f-full" id="prevCompanyWrap" style="display:none;">
        <label>Previous Company Name</label>
        <div class="input-box">
            <i class="fas fa-history ico"></i>
            <input asp-for="PreviousCompany"
                   placeholder="e.g. Infosys, Local IT Firm..." />
        </div>
        <span asp-validation-for="PreviousCompany" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label>Description / Additional Details <span class="req">*</span></label>
        <div class="input-box no-ico">
            <textarea asp-for="Description" rows="4"
                      placeholder="Describe your internship issue or request..."
                      required></textarea>
        </div>
        <span asp-validation-for="Description" class="field-error"></span>
    </div>

</div>

<input type="hidden" asp-for="Type" />
<input type="hidden" asp-for="StudentName" />
<input type="hidden" asp-for="StudentEmail" />
<input type="hidden" asp-for="StudentRollNo" />
<input type="hidden" asp-for="StudentDepartment" />
<input type="hidden" asp-for="StudentPhone" />

<script>
    // Previous Experience Display Logic
    const hasPrev = document.getElementById('hasPrevExp');
    const prevWrap = document.getElementById('prevCompanyWrap');
    if (hasPrev) {
        hasPrev.addEventListener('change', () => {
            prevWrap.style.display = hasPrev.checked ? 'block' : 'none';
        });
    }

    // Dynamic Tracking for 'Other' Preferred Field Selection
    const fieldSelect = document.getElementById('preferredFieldSelect');
    const customFieldWrap = document.getElementById('customPreferredFieldWrap');
    const customFieldInput = document.getElementById('customPreferredFieldInput');

    if (fieldSelect && customFieldWrap && customFieldInput) {
        fieldSelect.addEventListener('change', function () {
            if (this.value === 'Other') {
                customFieldWrap.style.display = 'block';
                customFieldInput.setAttribute('required', 'required');
                customFieldInput.name = "PreferredField"; 
                fieldSelect.removeAttribute('name');       
            } else {
                customFieldWrap.style.display = 'none';
                customFieldInput.removeAttribute('required');
                customFieldInput.value = '';
                customFieldInput.removeAttribute('name');
                fieldSelect.setAttribute('name', 'PreferredField'); 
            }
        });
    }
</script>