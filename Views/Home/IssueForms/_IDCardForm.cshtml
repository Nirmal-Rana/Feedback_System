@model CollegeIssueManagement.Models.ViewModels.IDCardIssueViewModel

<div class="fields-grid">

    <div class="field f-full">
        <label>ID Card Issue Type <span class="req">*</span></label>
        <div class="input-box no-ico sel-box">
            <select asp-for="IDCardIssue" required>
                <option value="">Select issue type</option>
                <option>Lost ID Card</option>
                <option>Damaged ID Card</option>
                <option>New ID Card Request</option>
                <option>ID Card Not Working</option>
                <option>Wrong Information on Card</option>
            </select>
        </div>
        <span asp-validation-for="IDCardIssue" class="field-error"></span>
    </div>

    <div class="field">
        <label>Existing ID Card Number (if any)</label>
        <div class="input-box">
            <i class="fas fa-id-card ico"></i>
            <input asp-for="IDCardNumber"
                   placeholder="e.g. 2021-BIT-001" />
        </div>
        <span asp-validation-for="IDCardNumber" class="field-error"></span>
    </div>

    <div class="field">
        <label>Date of Loss / Damage</label>
        <div class="input-box">
            <i class="fas fa-calendar-alt ico"></i>
            <input asp-for="IncidentDate" type="date" />
        </div>
        <span asp-validation-for="IncidentDate" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label>Alternative Identification (Driving License, Citizenship, etc.)</label>
        <div class="input-box">
            <i class="fas fa-passport ico"></i>
            <input asp-for="AlternativeID"
                   placeholder="e.g. Citizenship No: 12-345-67" />
        </div>
        <span asp-validation-for="AlternativeID" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label>Description / Additional Details <span class="req">*</span></label>
        <div class="input-box no-ico">
            <textarea asp-for="Description" rows="4"
                      placeholder="Describe the issue in detail..."
                      required></textarea>
        </div>
        <span asp-validation-for="Description" class="field-error"></span>
    </div>

</div>

@* Hidden base fields *@
<input type="hidden" asp-for="Type" />
<input type="hidden" asp-for="StudentName" />
<input type="hidden" asp-for="StudentEmail" />
<input type="hidden" asp-for="StudentRollNo" />
<input type="hidden" asp-for="StudentDepartment" />
<input type="hidden" asp-for="StudentPhone" />