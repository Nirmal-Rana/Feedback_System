@model CollegeIssueManagement.Models.ViewModels.IDCardIssueViewModel

<div class="fields-grid">

    <div class="field f-full">
        <label>ID Card Issue Type <span class="req">*</span></label>
        <div class="input-box no-ico sel-box">
            <select asp-for="IDCardIssue" required>
                <option value="">Select issue type</option>
                <option value="Lost ID Card">Lost ID Card</option>
                <option value="Damaged ID Card">Damaged ID Card</option>
                <option value="New ID Card Request">New ID Card Request</option>
                <option value="ID Card Not Working">ID Card Not Working</option>
                <option value="Wrong Information on Card">
                    Wrong Information on Card
                </option>
            </select>
        </div>
        <span asp-validation-for="IDCardIssue" class="field-error"></span>
    </div>

    <div class="field f-full">
        <label>Description / Additional Details <span class="req">*</span></label>
        <div class="input-box no-ico">
            <textarea asp-for="Description" rows="4"
                      placeholder="Describe the issue in detail..."
                      required></textarea>
        </div>
        <span asp-validation-for="Description" class="field-error"></span>
    </div>

</div>

<input type="hidden" asp-for="Type" />