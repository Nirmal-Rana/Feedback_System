@{
    ViewData["Title"] = "Scan QR Code";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Scan QR Code to Submit Issue</h4>
                </div>
                <div class="card-body text-center">
                    <div id="reader" style="width: 100%;"></div>

                    <div class="mt-3">
                        <button id="startScanner" class="btn btn-primary">Start Scanner</button>
                        <button id="stopScanner" class="btn btn-danger" style="display:none;">Stop Scanner</button>
                    </div>

                    <div id="result" class="mt-3"></div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    <h5>Manual Entry</h5>
                    <form asp-action="ProcessQRScan" method="post">
                        <div class="mb-3">
                            <label class="form-label">Enter QR Code Data</label>
                            <input type="text" name="qrData" class="form-control" placeholder="Paste QR code data here">
                        </div>
                        <button type="submit" class="btn btn-secondary">Submit</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.0.9/dist/html5-qrcode.min.js"></script>
    <script>
        let html5QrcodeScanner = null;

        document.getElementById('startScanner').addEventListener('click', function() {
        const config = {
        fps: 10,
        qrbox: { width: 250, height: 250 },
        aspectRatio: 1.0
        };

        html5QrcodeScanner = new Html5QrcodeScanner("reader", config, false);

        html5QrcodeScanner.render(onScanSuccess, onScanError);

        document.getElementById('startScanner').style.display = 'none';
        document.getElementById('stopScanner').style.display = 'block';
        });

        document.getElementById('stopScanner').addEventListener('click', function() {
        if (html5QrcodeScanner) {
        html5QrcodeScanner.clear();
        document.getElementById('startScanner').style.display = 'block';
        document.getElementById('stopScanner').style.display = 'none';
        }
        });

        function onScanSuccess(decodedText, decodedResult) {
        // Process the QR code data
        fetch('@Url.Action("ProcessQRScan", "Home")', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'qrData=' + encodeURIComponent(decodedText)
        }).then(response => {
        if (response.redirected) {
        window.location.href = response.url;
        }
        });
        }

        function onScanError(errorMessage) {
        console.error(errorMessage);
        }
    </script>
}