@model CollegeIssueManagement.Models.Issue

@{
    ViewData["Title"] = "Issue Submitted Successfully";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .confirmation-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 25px 70px rgba(0,0,0,0.3);
            max-width: 600px;
            width: 100%;
            overflow: hidden;
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @@keyframes popIn {
            from { opacity: 0; transform: scale(0.85); }
            to   { opacity: 1; transform: scale(1); }
        }

        .confirmation-header {
            background: linear-gradient(135deg, #43e97b, #38f9d7);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }

        .check-circle {
            width: 80px;
            height: 80px;
            background: rgba(255,255,255,0.25);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2.5rem;
            animation: scaleIn 0.4s ease 0.3s both;
        }

        @@keyframes scaleIn {
            from { transform: scale(0); }
            to   { transform: scale(1); }
        }

        .confirmation-header h1 { font-size: 1.8rem; margin-bottom: 8px; }
        .confirmation-header p  { opacity: 0.9; font-size: 1rem; }

        .confirmation-body { padding: 30px; }

        .issue-id-box {
            background: #f8f9ff;
            border: 2px dashed #667eea;
            border-radius: 14px;
            padding: 20px;
            text-align: center;
            margin-bottom: 24px;
        }

        .issue-id-box .label {
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #888;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .issue-id-box .id-number {
            font-size: 2rem;
            font-weight: 800;
            color: #667eea;
        }

        .issue-id-box .save-note {
            font-size: 0.82rem;
            color: #999;
            margin-top: 6px;
        }

        .details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 24px;
        }

        .detail-item {
            background: #f8f9ff;
            border-radius: 12px;
            padding: 14px;
        }

        .detail-item .d-label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #999;
            margin-bottom: 4px;
        }

        .detail-item .d-value {
            font-size: 0.92rem;
            font-weight: 600;
            color: #333;
        }

        .type-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.82rem;
            font-weight: 700;
            background: #e3f2fd;
            color: #1565c0;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.82rem;
            font-weight: 700;
            background: #fff3cd;
            color: #856404;
        }

        .info-box {
            background: #fff8e1;
            border-left: 4px solid #ffc107;
            border-radius: 0 12px 12px 0;
            padding: 14px 16px;
            margin-bottom: 24px;
            font-size: 0.88rem;
            color: #555;
            line-height: 1.6;
        }

        .info-box i { color: #ffc107; margin-right: 6px; }

        .action-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-primary {
            flex: 1;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 13px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.92rem;
            text-align: center;
            transition: opacity 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
        }

        .btn-secondary {
            flex: 1;
            background: #f1f1f1;
            color: #555;
            padding: 13px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.92rem;
            text-align: center;
            transition: background 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
        }

        .btn-primary:hover { opacity: 0.88; color: white; text-decoration: none; }
        .btn-secondary:hover { background: #e0e0e0; color: #333; text-decoration: none; }
    </style>
</head>
<body>
    <div class="confirmation-card">
        <div class="confirmation-header">
            <div class="check-circle">
                <i class="fas fa-check"></i>
            </div>
            <h1>Issue Submitted!</h1>
            <p>Your issue has been received and is being reviewed by our team.</p>
        </div>

        <div class="confirmation-body">
            <div class="issue-id-box">
                <div class="label">Your Issue Reference ID</div>
                <div class="id-number">#@Model.Id</div>
                <div class="save-note">
                    <i class="fas fa-bookmark"></i>
                    Save this ID to track your issue status
                </div>
            </div>

            <div class="details-grid">
                <div class="detail-item">
                    <div class="d-label">Student Name</div>
                    <div class="d-value">@Model.StudentName</div>
                </div>
                <div class="detail-item">
                    <div class="d-label">Roll Number</div>
                    <div class="d-value">@Model.StudentRollNo</div>
                </div>
                <div class="detail-item">
                    <div class="d-label">Issue Type</div>
                    <div class="d-value">
                        <span class="type-badge">@Model.Type</span>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="d-label">Current Status</div>
                    <div class="d-value">
                        <span class="status-badge">@Model.Status</span>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="d-label">Submitted On</div>
                    <div class="d-value">@Model.SubmittedDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="detail-item">
                    <div class="d-label">Email</div>
                    <div class="d-value" style="font-size:0.8rem; word-break:break-all;">@Model.StudentEmail</div>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-envelope"></i>
                You will receive an <strong>email notification</strong> at
                <strong>@Model.StudentEmail</strong> when your issue status is updated.
                Please check your inbox regularly.
            </div>

            <div class="action-buttons">
                <a asp-controller="Home" asp-action="IssueStatus"
                   asp-route-id="@Model.Id" class="btn-primary">
                    <i class="fas fa-search"></i> Track Issue
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn-secondary">
                    <i class="fas fa-home"></i> Go Home
                </a>
            </div>
        </div>
    </div>
</body>
</html>