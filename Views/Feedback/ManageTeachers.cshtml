@model List<CollegeIssueManagement.Models.Teacher>
@{
    Layout = null;
    var feedbackCounts = ViewBag.FeedbackCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    const int visibleRowLimit = 10;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Teachers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f0f2f8;
                color: #0f172a;
            }

            input[type="checkbox"] {
                accent-color: #a855f7;
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            .app-sidebar {
                width: 220px;
                background-color: #0a1628;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                position: sticky;
                top: 0;
                height: 100vh;
                overflow: hidden;
            }

                .app-sidebar::after {
                    content: '';
                    position: absolute;
                    top: 55%;
                    left: -40px;
                    width: 290px;
                    height: 290px;
                    background-image: url('/image/sidelogo.png');
                    background-size: contain;
                    background-repeat: no-repeat;
                    background-position: top left;
                    opacity: 0.92;
                    pointer-events: none;
                    z-index: 0;
                }

            .sidebar-brand {
                padding: 16px 14px 14px;
                display: flex;
                flex-direction: column;
                align-items: center;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                position: relative;
                z-index: 2;
            }

                .sidebar-brand img {
                    width: 160px;
                    height: auto;
                    object-fit: contain;
                }

            .sidebar-nav {
                flex: 1;
                padding: 12px 10px;
                display: flex;
                flex-direction: column;
                gap: 2px;
                position: relative;
                z-index: 2;
                overflow-y: auto;
            }

                .sidebar-nav::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar-nav::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar-nav::-webkit-scrollbar-thumb {
                    background: #1e293b;
                    border-radius: 2px;
                }

            .sidebar-section-label {
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: #e879a0;
                padding: 14px 8px 5px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 12px;
                border-radius: 10px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 500;
                transition: all 0.15s ease;
                position: relative;
            }

                .sidebar-link i {
                    font-size: 0.85rem;
                    width: 16px;
                    text-align: center;
                    flex-shrink: 0;
                }

                .sidebar-link:hover {
                    background: rgba(255,255,255,0.07);
                    color: #e2e8f0;
                    text-decoration: none;
                }

                .sidebar-link.active {
                    background: linear-gradient(135deg, #e879f9, #a855f7);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 14px rgba(168,85,247,0.4);
                }

                    .sidebar-link.active i {
                        color: #ffffff;
                    }

                .sidebar-link.danger {
                    color: #cbd5e1;
                }

                    .sidebar-link.danger:hover {
                        color: #f8fafc;
                        background: rgba(255,255,255,0.07);
                    }

            .sidebar-footer {
                padding: 10px 10px 14px;
                border-top: 1px solid rgba(255,255,255,0.05);
                position: relative;
                z-index: 2;
            }

            .app-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
                background: #f0f2f8;
            }

            .app-topbar {
                height: 64px;
                background: white;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topbar-title-block .page-title {
                font-size: 1.05rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .topbar-title-block .page-title i {
                    color: #e879f9;
                }

            .topbar-title-block .page-sub {
                font-size: 0.72rem;
                color: #64748b;
                margin-top: 1px;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 14px;
            }

            .topbar-user {
                display: flex;
                align-items: center;
                gap: 9px;
                padding: 5px 10px 5px 5px;
                border-radius: 24px;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                cursor: pointer;
            }

            .user-avatar {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: linear-gradient(135deg, #e879f9, #a855f7);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 0.85rem;
            }

            .user-info-text .user-name {
                font-size: 0.75rem;
                font-weight: 600;
                color: #0f172a;
                line-height: 1.2;
            }

            .user-info-text .user-role {
                font-size: 0.65rem;
                color: #64748b;
            }

            .app-content {
                flex: 1;
                padding: 22px 24px;
            }

            .container {
                max-width: 1150px;
                margin: 0 auto;
            }

            .alert {
                padding: 12px 16px;
                border-radius: 9px;
                margin-bottom: 16px;
                font-size: 0.86rem;
                display: flex;
                align-items: center;
                gap: 9px;
            }

            .alert-success {
                background: #f0fdf4;
                border: 1px solid #bbf7d0;
                color: #15803d;
            }

            .alert-error {
                background: #fef2f2;
                border: 1px solid #fecaca;
                color: #b91c1c;
            }

            .page-actions-bar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 20px;
                flex-wrap: wrap;
                gap: 12px;
            }

                .page-actions-bar h1 {
                    font-size: 1.05rem;
                    font-weight: 700;
                    color: #0f172a;
                }

            .card-title {
                font-size: 0.88rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .card-title i {
                    color: #e879f9;
                }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 6px;
                margin-bottom: 18px;
            }

                .form-group label {
                    font-size: 0.82rem;
                    font-weight: 600;
                    color: #475569;
                }

                .form-group input, .form-group select {
                    width: 100%;
                    padding: 11px 13px;
                    border: 1px solid #cbd5e1;
                    border-radius: 8px;
                    font-family: inherit;
                    font-size: 0.88rem;
                    background: #f8fafc;
                    color: #0f172a;
                    outline: none;
                    transition: border-color 0.15s;
                }

                    .form-group input:focus, .form-group select:focus {
                        border-color: #a855f7;
                    }

            .form-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }

            .custom-dropdown {
                position: relative;
                width: 100%;
            }

            .dropdown-btn {
                width: 100%;
                padding: 11px 13px;
                border: 1px solid #cbd5e1;
                border-radius: 8px;
                font-family: inherit;
                font-size: 0.88rem;
                background: #f8fafc;
                color: #0f172a;
                outline: none;
                display: flex;
                justify-content: space-between;
                align-items: center;
                cursor: pointer;
                transition: border-color 0.15s, background 0.15s;
            }

                .dropdown-btn:focus, .dropdown-btn:hover {
                    border-color: #a855f7;
                    background: #ffffff;
                }

            .dropdown-options {
                display: none;
                position: absolute;
                top: 105%;
                left: 0;
                width: 100%;
                background: #ffffff;
                border: 1px solid #cbd5e1;
                border-radius: 8px;
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
                z-index: 100;
                max-height: 320px;
                overflow-y: auto;
                padding: 8px;
            }

                .dropdown-options.show {
                    display: block;
                }

                .dropdown-options .checkbox-label {
                    padding: 7px 9px;
                    border-radius: 6px;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    font-size: 0.84rem;
                    color: #334155;
                    cursor: pointer;
                    transition: background 0.1s;
                }

                    .dropdown-options .checkbox-label:hover {
                        background: #f1f5f9;
                    }

                    .dropdown-options .checkbox-label input {
                        cursor: pointer;
                        width: auto;
                    }

            .btn {
                padding: 9px 18px;
                border-radius: 8px;
                font-size: 0.84rem;
                font-weight: 600;
                cursor: pointer;
                border: none;
                display: inline-flex;
                align-items: center;
                gap: 7px;
                text-decoration: none;
                transition: all 0.15s;
            }

                .btn:disabled {
                    opacity: 0.6;
                    cursor: not-allowed;
                }

            .btn-indigo {
                background: linear-gradient(135deg, #e879f9, #a855f7);
                color: white;
                box-shadow: 0 4px 12px rgba(168,85,247,0.3);
            }

                .btn-indigo:hover {
                    background: linear-gradient(135deg, #d946ef, #9333ea);
                    color: white;
                }

            .btn-red {
                background: #fee2e2;
                color: #ef4444;
                border: 1px solid #fecaca;
            }

                .btn-red:hover {
                    background: #ef4444;
                    color: white;
                    border-color: #ef4444;
                }

            .btn-outline {
                background: white;
                color: #475569;
                border: 1px solid #cbd5e1;
            }

                .btn-outline:hover {
                    background: #f8fafc;
                    color: #0f172a;
                }

            /* ── Add / Edit Teacher modal ──
                           NOTE: overflow is intentionally NOT set to hidden on .modal-panel.
                           The Semester/Section dropdowns are absolutely-positioned children;
                           overflow:hidden on an ancestor clips them, which was the bug where
                           only the first few semesters/sections were visible. The backdrop
                           below still scrolls (overflow-y:auto) if the panel is tall. */
            .modal-backdrop {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(15, 23, 42, 0.55);
                z-index: 300;
                align-items: flex-start;
                justify-content: center;
                padding: 30px 20px;
                overflow-y: auto;
            }

                .modal-backdrop.show {
                    display: flex;
                }

            .modal-panel {
                background: white;
                border-radius: 16px;
                width: 100%;
                max-width: 880px;
                box-shadow: 0 25px 50px -12px rgba(0,0,0,0.35);
                animation: modalPop 0.18s ease;
            }

            @@keyframes modalPop {
                from {
                    opacity: 0;
                    transform: translateY(-8px) scale(0.98);
                }

                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }

            .modal-panel-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 22px 30px;
                border-bottom: 1px solid #e2e8f0;
            }

                .modal-panel-header .card-title {
                    font-size: 1rem;
                }

            .modal-close-btn {
                background: #f1f5f9;
                border: none;
                width: 32px;
                height: 32px;
                border-radius: 8px;
                color: #64748b;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.15s;
                flex-shrink: 0;
            }

                .modal-close-btn:hover {
                    background: #e2e8f0;
                    color: #0f172a;
                }

            /* ── Assignments cell (contained width + expandable) ── */
            .assign-chip {
                display: inline-block;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 6px;
                padding: 3px 8px;
                font-size: 0.74rem;
                color: #475569;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                max-width: 100%;
            }

                .assign-chip strong {
                    color: #a855f7;
                }

            .assign-cell-wrap {
                max-width: 220px;
            }

            .assign-extra {
                display: none;
                flex-direction: column;
                gap: 4px;
                margin-top: 4px;
            }

                .assign-extra.expanded {
                    display: flex;
                }

            .assign-more-btn {
                background: none;
                border: none;
                padding: 2px 0;
                margin-top: 4px;
                font-size: 0.74rem;
                font-weight: 600;
                color: #a855f7;
                cursor: pointer;
                text-align: left;
            }

                .assign-more-btn:hover {
                    text-decoration: underline;
                }

            .table-card {
                background: white;
                border-radius: 14px;
                border: 1px solid #e8edf5;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
                overflow: hidden;
            }

            .table-top {
                padding: 16px 20px;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                background: #fafafa;
                flex-wrap: wrap;
                gap: 12px;
            }

                .table-top h2 {
                    font-size: 0.9rem;
                    font-weight: 700;
                    color: #0f172a;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                    .table-top h2 i {
                        color: #e879f9;
                    }

                .table-top .table-controls {
                    display: flex;
                    align-items: center;
                    gap: 14px;
                }

            .search-wrapper {
                position: relative;
            }

                .search-wrapper i {
                    position: absolute;
                    left: 10px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 0.8rem;
                }

            .search-input {
                padding: 7px 12px 7px 30px;
                font-size: 0.82rem;
                border: 1px solid #cbd5e1;
                border-radius: 6px;
                outline: none;
                width: 200px;
                transition: all 0.15s;
            }

                .search-input:focus {
                    border-color: #a855f7;
                    width: 260px;
                }

            .table-top span {
                font-size: 0.78rem;
                color: #64748b;
            }

            #bulkDeleteBtn {
                padding: 7px 14px;
                font-size: 0.8rem;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            thead th {
                background: #f8fafc;
                padding: 11px 16px;
                font-size: 0.7rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: #64748b;
                text-align: left;
                border-bottom: 1px solid #e2e8f0;
            }

            tbody tr {
                border-bottom: 1px solid #f1f5f9;
                transition: background 0.1s;
            }

                tbody tr:last-child {
                    border-bottom: none;
                }

                tbody tr:hover {
                    background: #fdf4ff;
                }

            tbody td {
                padding: 13px 16px;
                font-size: 0.86rem;
                vertical-align: middle;
            }

            /* ── Name column: no wrap, roomy ── */
            .teacher-name-cell {
                min-width: 100px;
                white-space: nowrap;
            }

                .teacher-name-cell .teacher-name {
                    white-space: nowrap;
                }

            .empty-state {
                text-align: center;
                padding: 52px 20px;
                color: #94a3b8;
            }

                .empty-state i {
                    font-size: 2.4rem;
                    margin-bottom: 12px;
                    display: block;
                    color: #cbd5e1;
                }

            .table-responsive {
                width: 100%;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

                .table-responsive table {
                    min-width: 1050px;
                }

            .show-more-wrap {
                padding: 16px 20px;
                text-align: center;
                border-top: 1px solid #f1f5f9;
            }

            .app-footer {
                background: white;
                border-top: 1px solid #e2e8f0;
                padding: 12px 28px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                font-size: 0.72rem;
                color: #94a3b8;
            }

            @@media (max-width: 900px) {
                .app-sidebar {
                    width: 60px;
                }

                .sidebar-link span, .sidebar-section-label {
                    display: none;
                }

                .sidebar-link {
                    justify-content: center;
                    padding: 10px;
                }

                .sidebar-brand {
                    padding: 14px 10px;
                    justify-content: center;
                }

                    .sidebar-brand img {
                        width: 36px;
                    }
            }

            @@media (max-width: 768px) {
                .form-grid {
                    grid-template-columns: 1fr;
                }
            }
    </style>
</head>
<body>
    <div class="app-shell">

        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <img src="/image/logo.png" alt="College Logo" />
            </div>
            <nav class="sidebar-nav">
                <a href="/Feedback/FeedbackDashboard" class="sidebar-link">
                    <i class="fas fa-home"></i><span>Dashboard</span>
                </a>
                <a href="/Feedback/ManageTeachers" class="sidebar-link active">
                    <i class="fas fa-users-cog"></i><span>Manage Teachers</span>
                </a>
                <span class="sidebar-section-label">Teachers</span>
                <a href="/Feedback/TeachersList" class="sidebar-link">
                    <i class="fas fa-user-graduate"></i><span>Teachers List</span>
                </a>
                <span class="sidebar-section-label">Reports</span>
                <a href="/Feedback/ExportFeedback" class="sidebar-link">
                    <i class="fas fa-download"></i><span>Export CSV</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <a href="/Feedback/FeedbackLogout" class="sidebar-link danger">
                    <i class="fas fa-arrow-left"></i><span>Back to Portal</span>
                </a>
            </div>
        </aside>

        <div class="app-main">
            <div class="app-topbar">
                <div class="topbar-title-block">
                    <div class="page-title"><i class="fas fa-users-cog"></i> Manage Teachers</div>
                    <div class="page-sub">Texas College of Management &amp; IT</div>
                </div>
                <div class="topbar-right">
                    <div class="topbar-user">
                        <div class="user-avatar"><i class="fas fa-user"></i></div>
                        <div class="user-info-text">
                            <div class="user-name">Texas College of</div>
                            <div class="user-role">Management &amp; IT</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-error"><i class="fas fa-exclamation-triangle"></i> @TempData["Error"]</div>
                    }

                    <div class="page-actions-bar">
                        <h1>Teachers</h1>
                        <button type="button" class="btn btn-indigo" onclick="openAddModal()">
                            <i class="fas fa-user-plus"></i> Add New Teacher
                        </button>
                    </div>

                    <div class="table-card">
                        <div class="table-top">
                            <h2><i class="fas fa-list"></i> All Teachers</h2>
                            <div class="table-controls">
                                <button type="button" id="bulkDeleteBtn" class="btn btn-red" style="display:none;" onclick="bulkDeleteTeachers()">
                                    <i class="fas fa-trash"></i> Delete Selected (<span id="selectedCount">0</span>)
                                </button>
                                <div class="search-wrapper">
                                    <i class="fas fa-search"></i>
                                    <input type="text" id="teacherSearch" class="search-input" placeholder="Search teacher name..." onkeyup="filterTeachers()" />
                                </div>
                                <span id="teacherCount">@Model.Count teacher@(Model.Count != 1 ? "s" : "")</span>
                            </div>
                        </div>

                        @if (Model.Any())
                        {
                            <div class="table-responsive">
                                <table id="teachersTable">
                                    <thead>
                                        <tr>
                                            <th style="width:36px;"><input type="checkbox" id="selectAllTeachers" onchange="toggleSelectAllTeachers(this)" /></th>
                                            <th>#</th>
                                            <th>Name</th>
                                            <th>Assignments</th>
                                            <th>Designation</th>
                                            <th>Feedbacks</th>
                                            <th>Added</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            int rowIndex = 0;
                                        }
                                        @foreach (var t in Model)
                                        {
                                            int tFeedbackCount = feedbackCounts.ContainsKey(t.Id) ? feedbackCounts[t.Id] : 0;
                                            var orderedAssignments = t.Assignments.OrderBy(a => a.Semester).ToList();
                                            bool isExtraRow = rowIndex >= visibleRowLimit;

                                            <tr class="teacher-row @(isExtraRow ? "extra-teacher-row" : "")" data-id="@t.Id" style="@(isExtraRow ? "display:none;" : "")">
                                                <td><input type="checkbox" class="teacher-select-checkbox" value="@t.Id" onchange="updateBulkDeleteState()" /></td>
                                                <td style="color:#94a3b8;font-size:0.8rem;">@t.Id</td>
                                                <td class="teacher-name-cell">
                                                    <div style="display:flex;align-items:center;gap:10px;">
                                                        @if (!string.IsNullOrEmpty(t.PhotoPath))
                                                        {
                                                            <img src="@t.PhotoPath" alt="@t.FullName" style="width:34px;height:34px;border-radius:9px;object-fit:cover;flex-shrink:0;" />
                                                        }
                                                        else
                                                        {
                                                            <div style="width:34px;height:34px;border-radius:9px;background:#f3e8ff;color:#a855f7;display:flex;align-items:center;justify-content:center;font-size:0.85rem;flex-shrink:0;">
                                                                <i class="fas fa-user"></i>
                                                            </div>
                                                        }
                                                        <div class="teacher-name" style="font-weight:600;color:#0f172a;">@t.FullName</div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="assign-cell-wrap">
                                                        @if (orderedAssignments.Any())
                                                        {
                                                            var first = orderedAssignments[0];
                                                            var rest = orderedAssignments.Skip(1).ToList();

                                                            <span class="assign-chip">
                                                                <strong>@first.Semester</strong> — @first.Subject
                                                                @if (!string.IsNullOrEmpty(first.Section))
                                                                {
                                                                    <span>(@first.Section)</span>
                                                                }
                                                            </span>

                                                            @if (rest.Any())
                                                            {
                                                                <div class="assign-extra" id="assignExtra-@t.Id">
                                                                    @foreach (var a in rest)
                                                                    {
                                                                        <span class="assign-chip">
                                                                            <strong>@a.Semester</strong> — @a.Subject
                                                                            @if (!string.IsNullOrEmpty(a.Section))
                                                                            {
                                                                                <span>(@a.Section)</span>
                                                                            }
                                                                        </span>
                                                                    }
                                                                </div>
                                                                <button type="button" class="assign-more-btn" id="assignToggleBtn-@t.Id" onclick="toggleAssignments(@t.Id, @rest.Count)">
                                                                    +@rest.Count more
                                                                </button>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span style="color:#94a3b8;font-size:0.78rem;">No subjects assigned</span>
                                                        }
                                                    </div>
                                                </td>
                                                <td style="color:#64748b;">@(t.Designation ?? "—")</td>
                                                <td>
                                                    <span class="assign-chip" style="color:#a855f7;">
                                                        @tFeedbackCount feedback@(tFeedbackCount != 1 ? "s" : "")
                                                    </span>
                                                </td>
                                                <td style="color:#94a3b8;font-size:0.8rem;">@t.CreatedAt.ToString("dd MMM yyyy")</td>
                                                <td>
                                                    <div style="display:flex;gap:8px;align-items:center;">
                                                        <button type="button"
                                                                class="btn btn-outline teacher-edit-btn"
                                                                style="padding:5px 12px;font-size:0.78rem;"
                                                                data-id="@t.Id"
                                                                data-fullname="@t.FullName"
                                                                data-designation="@t.Designation"
                                                                data-photo="@t.PhotoPath"
                                                                data-assignments='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(orderedAssignments.Select(a => new { semester = a.Semester, subject = a.Subject, section = a.Section })))'>
                                                            <i class="fas fa-pen"></i> Edit
                                                        </button>
                                                        <a href="/Feedback/TeacherDetail/@t.Id" class="btn btn-outline" style="padding:5px 12px;font-size:0.78rem;">
                                                            <i class="fas fa-eye"></i> View
                                                        </a>
                                                        <form method="post" asp-controller="Feedback" asp-action="DeleteTeacher" style="display:inline;" onsubmit="return confirm('Remove @t.FullName from the system?')">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@t.Id" />
                                                            <button type="submit" class="btn btn-red" style="padding:5px 12px;font-size:0.78rem;">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                            rowIndex++;
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (Model.Count > visibleRowLimit)
                            {
                                <div class="show-more-wrap">
                                    <button type="button" id="showMoreTeachersBtn" class="btn btn-outline" onclick="showMoreTeachers()">
                                        <i class="fas fa-chevron-down"></i> Show More Teachers (@(Model.Count - visibleRowLimit) more)
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="fas fa-user-slash"></i>
                                <p style="font-size:0.94rem;font-weight:600;color:#475569;">No teachers added yet</p>
                                <p style="font-size:0.82rem;margin-top:4px;">Use the "Add New Teacher" button above to add your first teacher</p>
                            </div>
                        }
                    </div>

                </div>
            </div>
            <div class="app-footer">
                <span>© 2026 Texas International College. All rights reserved.</span>
                <span>Version 1.0.0</span>
            </div>
        </div>
    </div>

    <!-- ══ Add / Edit Teacher Modal — wizard ══ -->
    <div class="modal-backdrop" id="teacherModalBackdrop" onclick="closeTeacherModalOnBackdrop(event)">
        <div class="modal-panel">
            <div class="modal-panel-header">
                <div class="card-title">
                    <i class="fas fa-user-plus" id="modalIcon"></i>
                    <span id="modalTitleText">Add New Teacher</span>
                </div>
                <button type="button" class="modal-close-btn" onclick="closeTeacherModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <form id="teacherForm" asp-controller="Feedback" asp-action="AddTeacher" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="teacherIdField" value="0" />
                <input type="hidden" name="AssignmentsJson" id="assignmentsJsonField" value="[]" />

                <div style="padding:34px;">

                    <!-- STEP: Basic info (static) -->
                    <div id="stepBasic">
                        <div class="form-group">
                            <label>Teacher Photo</label>
                            <div style="display:flex;align-items:center;gap:14px;">
                                <div style="width:64px;height:64px;border-radius:12px;overflow:hidden;border:1px solid #cbd5e1;background:#f8fafc;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                    <img id="photoPreview" src="" alt="Preview" style="width:100%;height:100%;object-fit:cover;display:none;" />
                                    <i class="fas fa-user" id="photoPreviewIcon" style="color:#cbd5e1;font-size:1.6rem;"></i>
                                </div>
                                <div style="flex:1;">
                                    <input type="file" name="PhotoFile" id="photoFileInput" accept=".jpg,.jpeg,.png,.webp" onchange="previewPhoto(this)" />
                                    <div style="font-size:0.72rem;color:#94a3b8;margin-top:4px;">JPG, PNG or WEBP. Max 3MB.</div>
                                    <div id="removePhotoWrap" style="display:none;margin-top:6px;">
                                        <label style="font-size:0.78rem;color:#64748b;display:flex;align-items:center;gap:6px;cursor:pointer;">
                                            <input type="checkbox" name="RemovePhoto" value="true" /> Remove current photo
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Full Name *</label>
                            <input type="text" name="FullName" id="fullNameInput" placeholder="Full Name" required />
                        </div>

                        <div class="form-group">
                            <label>Designation</label>
                            <input type="text" name="Designation" id="designationInput" placeholder="Designation (e.g. Lecturer)" />
                        </div>

                        <div style="display:flex;justify-content:flex-end;margin-top:18px;">
                            <button type="button" class="btn btn-indigo" onclick="goToAssignments()">
                                Next <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP: Subject assignment cards (dynamic, one at a time) -->
                    <div id="stepAssignment" style="display:none;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                            <div class="card-title" style="font-size:0.85rem;">
                                <i class="fas fa-layer-group"></i> Subject Assignment
                                <span id="cardIndicator" style="color:#94a3b8;font-weight:500;font-size:0.78rem;"></span>
                            </div>
                            <button type="button" class="btn btn-red" style="padding:5px 10px;font-size:0.75rem;" id="removeCardBtn" onclick="removeCurrentCard()">
                                <i class="fas fa-trash"></i> Remove
                            </button>
                        </div>

                        <div class="form-group">
                            <label>Subject *</label>
                            <input type="text" id="cardSubjectInput" placeholder="e.g. Java, Python, HTML" />
                        </div>

                        <div class="form-grid">
                            <div class="form-group">
                                <label>Semesters *</label>
                                <div class="custom-dropdown" id="cardSemesterDropdown" data-placeholder="Select Semesters">
                                    <button type="button" class="dropdown-btn" onclick="toggleDropdown('cardSemesterOptions')">
                                        <span class="btn-text">Select Semesters</span>
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                    <div class="dropdown-options" id="cardSemesterOptions">
                                        @foreach (var s in new[] { "1st Semester", "2nd Semester", "3rd Semester", "4th Semester", "5th Semester", "6th Semester", "7th Semester", "8th Semester" })
                                        {
                                            <label class="checkbox-label">
                                                <input type="checkbox" class="card-sem-cb" value="@s" onchange="updateDropdownText('cardSemesterDropdown')"> @s
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Sections *</label>
                                <div class="custom-dropdown" id="cardSectionDropdown" data-placeholder="Select Sections">
                                    <button type="button" class="dropdown-btn" onclick="toggleDropdown('cardSectionOptions')">
                                        <span class="btn-text">Select Sections</span>
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                    <div class="dropdown-options" id="cardSectionOptions">
                                        @foreach (var letter in new[] { 'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J' })
                                        {
                                            <label class="checkbox-label">
                                                <input type="checkbox" class="card-sec-cb" value="@letter" onchange="updateDropdownText('cardSectionDropdown')"> Section @letter
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:22px;flex-wrap:wrap;gap:10px;">
                            <button type="button" class="btn btn-outline" onclick="prevCard()">
                                <i class="fas fa-arrow-left"></i> Previous
                            </button>
                            <div style="display:flex;gap:10px;">
                                <button type="button" class="btn btn-outline" id="nextCardBtn" onclick="nextCard()">
                                    Next <i class="fas fa-arrow-right"></i>
                                </button>
                                <button type="button" class="btn btn-indigo" onclick="saveTeacher()">
                                    <i class="fas fa-save"></i> <span id="saveBtnText">Save Teacher</span>
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <script>
            // ══ Generic dropdown handling ══
            function toggleDropdown(id) {
                document.querySelectorAll('.dropdown-options').forEach(el => {
                    if (el.id !== id) el.classList.remove('show');
                });
                document.getElementById(id).classList.toggle('show');
            }
            window.onclick = function(event) {
                if (!event.target.closest('.custom-dropdown')) {
                    document.querySelectorAll('.dropdown-options').forEach(el => el.classList.remove('show'));
                }
            }
            function updateDropdownText(dropdownId) {
                const dropdown = document.getElementById(dropdownId);
                const checkboxes = dropdown.querySelectorAll('.dropdown-options input[type="checkbox"]');
                const checkedBoxes = Array.from(checkboxes).filter(cb => cb.checked);
                const buttonText = dropdown.querySelector('.btn-text');
                const placeholder = dropdown.dataset.placeholder || 'Select';

                if (checkedBoxes.length === 0) {
                    buttonText.innerText = placeholder;
                } else if (checkedBoxes.length <= 2) {
                    buttonText.innerText = checkedBoxes.map(cb => cb.parentElement.textContent.trim()).join(', ');
                } else {
                    buttonText.innerText = checkedBoxes.length + " Items Selected";
                }
            }

            // ══ Photo preview ══
            function previewPhoto(input) {
                const preview = document.getElementById('photoPreview');
                const icon = document.getElementById('photoPreviewIcon');
                if (input.files && input.files[0]) {
                    preview.src = URL.createObjectURL(input.files[0]);
                    preview.style.display = 'block';
                    icon.style.display = 'none';
                }
            }
            function resetPhotoPreview() {
                const preview = document.getElementById('photoPreview');
                const icon = document.getElementById('photoPreviewIcon');
                preview.src = '';
                preview.style.display = 'none';
                icon.style.display = 'inline-block';
            }

            // ══ Modal open/close ══
            function openTeacherModal() {
                document.getElementById('teacherModalBackdrop').classList.add('show');
                document.body.style.overflow = 'hidden';
            }
            function closeTeacherModal() {
                document.getElementById('teacherModalBackdrop').classList.remove('show');
                document.body.style.overflow = '';
            }
            function closeTeacherModalOnBackdrop(evt) {
                if (evt.target.id === 'teacherModalBackdrop') closeTeacherModal();
            }
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') closeTeacherModal();
            });

            // ══ Assignments cell — expand/collapse "+N more" ══
            function toggleAssignments(teacherId, extraCount) {
                const extra = document.getElementById('assignExtra-' + teacherId);
                const btn = document.getElementById('assignToggleBtn-' + teacherId);
                if (!extra || !btn) return;

                const expanded = extra.classList.toggle('expanded');
                btn.textContent = expanded ? 'Show less' : ('+' + extraCount + ' more');
            }

            // ══ Show more teachers (pagination) ══
            function showMoreTeachers() {
                document.querySelectorAll('.extra-teacher-row').forEach(row => {
                    row.style.display = '';
                });
                const btn = document.getElementById('showMoreTeachersBtn');
                if (btn) btn.style.display = 'none';
            }

            // ══ Wizard state ══
            let wizardAssignments = [];
            let wizardIndex = 0;

            function emptyAssignment() { return { semesters: [], subject: '', sections: [] }; }

            function goToAssignments() {
                const name = document.getElementById('fullNameInput').value.trim();
                if (!name) { alert("Please enter the teacher's full name."); return; }
                if (wizardAssignments.length === 0) wizardAssignments.push(emptyAssignment());
                wizardIndex = 0;
                document.getElementById('stepBasic').style.display = 'none';
                document.getElementById('stepAssignment').style.display = 'block';
                renderCard();
            }

            function backToBasic() {
                syncCardFromDom();
                document.getElementById('stepAssignment').style.display = 'none';
                document.getElementById('stepBasic').style.display = 'block';
            }

            function renderCard() {
                const a = wizardAssignments[wizardIndex];
                document.getElementById('cardSubjectInput').value = a.subject || '';
                document.querySelectorAll('.card-sem-cb').forEach(cb => cb.checked = a.semesters.includes(cb.value));
                document.querySelectorAll('.card-sec-cb').forEach(cb => cb.checked = a.sections.includes(cb.value));
                updateDropdownText('cardSemesterDropdown');
                updateDropdownText('cardSectionDropdown');

                document.getElementById('cardIndicator').textContent = `(${wizardIndex + 1} of ${wizardAssignments.length})`;
                document.getElementById('removeCardBtn').style.display = wizardAssignments.length > 1 ? 'inline-flex' : 'none';

                const nextBtn = document.getElementById('nextCardBtn');
                nextBtn.innerHTML = (wizardIndex === wizardAssignments.length - 1)
                    ? '<i class="fas fa-plus"></i> Add Another Subject'
                    : 'Next <i class="fas fa-arrow-right"></i>';
            }

            function syncCardFromDom() {
                if (wizardAssignments.length === 0) return;
                const a = wizardAssignments[wizardIndex];
                a.subject = document.getElementById('cardSubjectInput').value.trim();
                a.semesters = Array.from(document.querySelectorAll('.card-sem-cb:checked')).map(cb => cb.value);
                a.sections = Array.from(document.querySelectorAll('.card-sec-cb:checked')).map(cb => cb.value);
            }

            function prevCard() {
                syncCardFromDom();
                if (wizardIndex > 0) {
                    wizardIndex--;
                    renderCard();
                } else {
                    backToBasic();
                }
            }

            function nextCard() {
                syncCardFromDom();
                const current = wizardAssignments[wizardIndex];
                if (!current.subject || current.semesters.length === 0 || current.sections.length === 0) {
                    alert('Please fill in Subject, Semester(s), and Section(s) before continuing.');
                    return;
                }
                if (wizardIndex === wizardAssignments.length - 1) {
                    wizardAssignments.push(emptyAssignment());
                }
                wizardIndex++;
                renderCard();
            }

            function removeCurrentCard() {
                if (wizardAssignments.length <= 1) return;
                wizardAssignments.splice(wizardIndex, 1);
                if (wizardIndex >= wizardAssignments.length) wizardIndex = wizardAssignments.length - 1;
                renderCard();
            }

            function saveTeacher() {
                syncCardFromDom();
                const valid = wizardAssignments.filter(a => a.subject && a.semesters.length && a.sections.length);
                if (valid.length === 0) {
                    alert('Please add at least one complete subject assignment (subject, semester, and section).');
                    return;
                }
                document.getElementById('assignmentsJsonField').value = JSON.stringify(valid);
                document.getElementById('teacherForm').submit();
            }

            // ══ Add / Edit entry points ══
            function openAddModal() {
                document.getElementById('modalTitleText').textContent = 'Add New Teacher';
                document.getElementById('modalIcon').className = 'fas fa-user-plus';
                document.getElementById('teacherForm').setAttribute('action', '/Feedback/AddTeacher');
                document.getElementById('teacherIdField').value = '0';

                document.getElementById('fullNameInput').value = '';
                document.getElementById('designationInput').value = '';
                document.getElementById('photoFileInput').value = '';
                document.getElementById('removePhotoWrap').style.display = 'none';
                resetPhotoPreview();

                wizardAssignments = [emptyAssignment()];
                wizardIndex = 0;
                document.getElementById('stepAssignment').style.display = 'none';
                document.getElementById('stepBasic').style.display = 'block';

                openTeacherModal();
            }

            function openEditModal(data) {
                document.getElementById('modalTitleText').textContent = 'Edit Teacher';
                document.getElementById('modalIcon').className = 'fas fa-user-edit';
                document.getElementById('teacherForm').setAttribute('action', '/Feedback/EditTeacher');
                document.getElementById('teacherIdField').value = data.id;

                document.getElementById('fullNameInput').value = data.fullName || '';
                document.getElementById('designationInput').value = data.designation || '';
                document.getElementById('photoFileInput').value = '';

                if (data.photoPath) {
                    const preview = document.getElementById('photoPreview');
                    const icon = document.getElementById('photoPreviewIcon');
                    preview.src = data.photoPath;
                    preview.style.display = 'block';
                    icon.style.display = 'none';
                    document.getElementById('removePhotoWrap').style.display = 'block';
                } else {
                    resetPhotoPreview();
                    document.getElementById('removePhotoWrap').style.display = 'none';
                }

                let raw = [];
                try { raw = JSON.parse(data.assignments || '[]'); } catch (e) { raw = []; }

                wizardAssignments = raw.map(a => ({
                    semesters: a.semester ? [a.semester] : [],
                    subject: a.subject || '',
                    sections: (a.section || '').split(',').map(s => s.trim()).filter(Boolean)
                }));
                if (wizardAssignments.length === 0) wizardAssignments = [emptyAssignment()];
                wizardIndex = 0;

                document.getElementById('stepAssignment').style.display = 'none';
                document.getElementById('stepBasic').style.display = 'block';

                openTeacherModal();
            }

            document.querySelectorAll('.teacher-edit-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    openEditModal({
                        id: this.dataset.id,
                        fullName: this.dataset.fullname,
                        designation: this.dataset.designation,
                        photoPath: this.dataset.photo,
                        assignments: this.dataset.assignments
                    });
                });
            });

            @if (TempData["Error"] != null)
                {
                    <text>
                            document.addEventListener('DOMContentLoaded', function () {
                                openAddModal();
                                                                                });
                    </text>
            }

                // ══ Bulk selection & delete ══
                function toggleSelectAllTeachers(masterCb) {
                    document.querySelectorAll('.teacher-select-checkbox').forEach(cb => {
                        if (cb.closest('.teacher-row').style.display !== 'none') {
                            cb.checked = masterCb.checked;
                        }
                    });
                    updateBulkDeleteState();
                }

            function updateBulkDeleteState() {
                const allBoxes = Array.from(document.querySelectorAll('.teacher-select-checkbox'));
                const visibleBoxes = allBoxes.filter(cb => cb.closest('.teacher-row').style.display !== 'none');
                const checked = allBoxes.filter(cb => cb.checked);

                document.getElementById('selectedCount').textContent = checked.length;
                document.getElementById('bulkDeleteBtn').style.display = checked.length > 0 ? 'inline-flex' : 'none';

                const selectAll = document.getElementById('selectAllTeachers');
                if (selectAll) {
                    selectAll.checked = visibleBoxes.length > 0 && visibleBoxes.every(cb => cb.checked);
                }
            }

            async function bulkDeleteTeachers() {
                const checked = Array.from(document.querySelectorAll('.teacher-select-checkbox:checked')).map(cb => parseInt(cb.value));
                if (checked.length === 0) return;

                if (!confirm(`Remove ${checked.length} teacher${checked.length !== 1 ? 's' : ''} from the system? This cannot be undone.`)) return;

                const btn = document.getElementById('bulkDeleteBtn');
                btn.disabled = true;

                try {
                    const res = await fetch('/Feedback/BulkDeleteTeachers', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(checked)
                    });

                    if (res.ok) {
                        checked.forEach(id => {
                            const row = document.querySelector(`.teacher-row[data-id="${id}"]`);
                            if (row) row.remove();
                        });
                        filterTeachers();
                        updateBulkDeleteState();
                    } else if (res.status === 401) {
                        alert('Your session has expired. Please log in again.');
                        window.location.href = '/Admin/Login';
                    } else {
                        alert('Something went wrong while deleting. Please try again.');
                    }
                } catch (err) {
                    alert('Network error. Please try again.');
                } finally {
                    btn.disabled = false;
                }
            }

            function filterTeachers() {
                var input = document.getElementById("teacherSearch");
                var filter = input.value.toLowerCase();
                var table = document.getElementById("teachersTable");
                if (!table) return;

                var rows = table.getElementsByClassName("teacher-row");
                var visibleCount = 0;
                var searching = filter.length > 0;

                for (var i = 0; i < rows.length; i++) {
                    var nameContainer = rows[i].getElementsByClassName("teacher-name")[0];
                    if (nameContainer) {
                        var nameText = nameContainer.textContent || nameContainer.innerText;
                        if (nameText.toLowerCase().indexOf(filter) > -1) {
                            rows[i].style.display = "";
                            visibleCount++;
                        } else {
                            rows[i].style.display = "none";
                            var cb = rows[i].querySelector('.teacher-select-checkbox');
                            if (cb) cb.checked = false;
                        }
                    }
                }

                // While actively searching, hide the "Show More" pagination button —
                // search should surface matches across the full list, not just the first page.
                var showMoreBtn = document.getElementById('showMoreTeachersBtn');
                if (showMoreBtn) {
                    showMoreBtn.style.display = searching ? 'none' : 'inline-flex';
                }

                var counter = document.getElementById("teacherCount");
                counter.innerText = visibleCount + " teacher" + (visibleCount !== 1 ? "s" : "") + " found";
                updateBulkDeleteState();
            }
    </script>
</body>
</html>
