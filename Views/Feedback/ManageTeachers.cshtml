@model List<CollegeIssueManagement.Models.Teacher>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Teachers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f0f2f8;
                color: #0f172a;
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            /* ══════════════════════════════
                       SIDEBAR
                    ══════════════════════════════ */
            .app-sidebar {
                width: 220px;
                background-color: #0a1628;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                position: sticky;
                top: 0;
                height: 100vh;
                overflow: hidden;
            }

                .app-sidebar::after {
                    content: '';
                    position: absolute;
                    top: 55%;
                    left: -40px;
                    width: 290px;
                    height: 290px;
                    background-image: url('/image/sidelogo.png');
                    background-size: contain;
                    background-repeat: no-repeat;
                    background-position: top left;
                    opacity: 0.92;
                    pointer-events: none;
                    z-index: 0;
                }

            .sidebar-brand {
                padding: 16px 14px 14px;
                display: flex;
                flex-direction: column;
                align-items: center;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                position: relative;
                z-index: 2;
            }

                .sidebar-brand img {
                    width: 160px;
                    height: auto;
                    object-fit: contain;
                }

            .sidebar-nav {
                flex: 1;
                padding: 12px 10px;
                display: flex;
                flex-direction: column;
                gap: 2px;
                position: relative;
                z-index: 2;
                overflow-y: auto;
            }

                .sidebar-nav::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar-nav::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar-nav::-webkit-scrollbar-thumb {
                    background: #1e293b;
                    border-radius: 2px;
                }

            .sidebar-section-label {
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: #e879a0;
                padding: 14px 8px 5px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 12px;
                border-radius: 10px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 500;
                transition: all 0.15s ease;
                position: relative;
            }

                .sidebar-link i {
                    font-size: 0.85rem;
                    width: 16px;
                    text-align: center;
                    flex-shrink: 0;
                }

                .sidebar-link:hover {
                    background: rgba(255,255,255,0.07);
                    color: #e2e8f0;
                    text-decoration: none;
                }

                .sidebar-link.active {
                    background: linear-gradient(135deg, #e879f9, #a855f7);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 14px rgba(168,85,247,0.4);
                }

                    .sidebar-link.active i {
                        color: #ffffff;
                    }

                .sidebar-link.danger {
                    color: #cbd5e1;
                }

                    .sidebar-link.danger:hover {
                        color: #f8fafc;
                        background: rgba(255,255,255,0.07);
                    }

            .sidebar-footer {
                padding: 10px 10px 14px;
                border-top: 1px solid rgba(255,255,255,0.05);
                position: relative;
                z-index: 2;
            }

            /* ══════════════════════════════
                       MAIN AREA
                    ══════════════════════════════ */
            .app-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
                background: #f0f2f8;
            }

            .app-topbar {
                height: 64px;
                background: white;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topbar-title-block .page-title {
                font-size: 1.05rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .topbar-title-block .page-title i {
                    color: #e879f9;
                }

            .topbar-title-block .page-sub {
                font-size: 0.72rem;
                color: #64748b;
                margin-top: 1px;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 14px;
            }

            .topbar-user {
                display: flex;
                align-items: center;
                gap: 9px;
                padding: 5px 10px 5px 5px;
                border-radius: 24px;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                cursor: pointer;
            }

            .user-avatar {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: linear-gradient(135deg, #e879f9, #a855f7);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 0.85rem;
            }

            .user-info-text .user-name {
                font-size: 0.75rem;
                font-weight: 600;
                color: #0f172a;
                line-height: 1.2;
            }

            .user-info-text .user-role {
                font-size: 0.65rem;
                color: #64748b;
            }

            .app-content {
                flex: 1;
                padding: 22px 24px;
            }

            .container {
                max-width: 1100px;
                margin: 0 auto;
            }

            /* ── Alert ── */
            .alert {
                padding: 12px 16px;
                border-radius: 9px;
                margin-bottom: 16px;
                font-size: 0.86rem;
                display: flex;
                align-items: center;
                gap: 9px;
            }

            .alert-success {
                background: #f0fdf4;
                border: 1px solid #bbf7d0;
                color: #15803d;
            }

            .alert-error {
                background: #fef2f2;
                border: 1px solid #fecaca;
                color: #b91c1c;
            }

            /* ── Add Teacher Card ── */
            .add-card {
                background: white;
                border-radius: 14px;
                padding: 22px 24px;
                border: 1px solid #e8edf5;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
                margin-bottom: 20px;
            }

            .card-title {
                font-size: 0.88rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 16px;
            }

                .card-title i {
                    color: #e879f9;
                }

            .form-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

                .form-group label {
                    font-size: 0.8rem;
                    font-weight: 600;
                    color: #475569;
                }

                .form-group input,
                .form-group select {
                    width: 100%;
                    padding: 10px 12px;
                    border: 1px solid #cbd5e1;
                    border-radius: 8px;
                    font-family: inherit;
                    font-size: 0.85rem;
                    background: #f8fafc;
                    color: #0f172a;
                    outline: none;
                    transition: border-color 0.15s;
                }

                    .form-group input:focus,
                    .form-group select:focus {
                        border-color: #a855f7;
                    }

            /* ── Custom Pop-up Dropdowns ── */
            .custom-dropdown {
                position: relative;
                width: 100%;
            }

            .dropdown-btn {
                width: 100%;
                padding: 10px 12px;
                border: 1px solid #cbd5e1;
                border-radius: 8px;
                font-family: inherit;
                font-size: 0.85rem;
                background: #f8fafc;
                color: #0f172a;
                outline: none;
                display: flex;
                justify-content: space-between;
                align-items: center;
                cursor: pointer;
                transition: border-color 0.15s, background 0.15s;
            }

                .dropdown-btn:focus, .dropdown-btn:hover {
                    border-color: #a855f7;
                    background: #ffffff;
                }

            .dropdown-options {
                display: none;
                position: absolute;
                top: 105%;
                left: 0;
                width: 100%;
                background: #ffffff;
                border: 1px solid #cbd5e1;
                border-radius: 8px;
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
                z-index: 100;
                max-height: 220px;
                overflow-y: auto;
                padding: 8px;
            }

                .dropdown-options.show {
                    display: block;
                }

                .dropdown-options .checkbox-label {
                    padding: 6px 8px;
                    border-radius: 6px;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    font-size: 0.82rem;
                    color: #334155;
                    cursor: pointer;
                    transition: background 0.1s;
                }

                    .dropdown-options .checkbox-label:hover {
                        background: #f1f5f9;
                    }

                    .dropdown-options .checkbox-label input {
                        cursor: pointer;
                        width: auto;
                    }

            .master-label {
                color: #a855f7 !important;
            }

            .dropdown-divider {
                border: 0;
                height: 1px;
                background: #e2e8f0;
                margin: 6px 4px;
            }

            .form-actions {
                grid-column: span 2;
                display: flex;
                justify-content: flex-end;
                margin-top: 8px;
            }

            /* ── Buttons ── */
            .btn {
                padding: 9px 18px;
                border-radius: 8px;
                font-size: 0.84rem;
                font-weight: 600;
                cursor: pointer;
                border: none;
                display: inline-flex;
                align-items: center;
                gap: 7px;
                text-decoration: none;
                transition: all 0.15s;
            }

            .btn-indigo {
                background: linear-gradient(135deg, #e879f9, #a855f7);
                color: white;
                box-shadow: 0 4px 12px rgba(168,85,247,0.3);
            }

                .btn-indigo:hover {
                    background: linear-gradient(135deg, #d946ef, #9333ea);
                    color: white;
                }

            .btn-red {
                background: #fee2e2;
                color: #ef4444;
                border: 1px solid #fecaca;
            }

                .btn-red:hover {
                    background: #ef4444;
                    color: white;
                    border-color: #ef4444;
                }

            .btn-outline {
                background: white;
                color: #475569;
                border: 1px solid #cbd5e1;
            }

                .btn-outline:hover {
                    background: #f8fafc;
                    color: #0f172a;
                }

            /* ── Table Card ── */
            .table-card {
                background: white;
                border-radius: 14px;
                border: 1px solid #e8edf5;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
                overflow: hidden;
            }

            .table-top {
                padding: 16px 20px;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                background: #fafafa;
                flex-wrap: wrap;
                gap: 12px;
            }

                .table-top h2 {
                    font-size: 0.9rem;
                    font-weight: 700;
                    color: #0f172a;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                    .table-top h2 i {
                        color: #e879f9;
                    }

                .table-top .table-controls {
                    display: flex;
                    align-items: center;
                    gap: 14px;
                }

            .search-wrapper {
                position: relative;
            }

                .search-wrapper i {
                    position: absolute;
                    left: 10px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 0.8rem;
                }

            .search-input {
                padding: 7px 12px 7px 30px;
                font-size: 0.82rem;
                border: 1px solid #cbd5e1;
                border-radius: 6px;
                outline: none;
                width: 200px;
                transition: all 0.15s;
            }

                .search-input:focus {
                    border-color: #a855f7;
                    width: 260px;
                }

            .table-top span {
                font-size: 0.78rem;
                color: #64748b;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            thead th {
                background: #f8fafc;
                padding: 11px 16px;
                font-size: 0.7rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: #64748b;
                text-align: left;
                border-bottom: 1px solid #e2e8f0;
            }

            tbody tr {
                border-bottom: 1px solid #f1f5f9;
                transition: background 0.1s;
            }

                tbody tr:last-child {
                    border-bottom: none;
                }

                tbody tr:hover {
                    background: #fdf4ff;
                }

            tbody td {
                padding: 13px 16px;
                font-size: 0.86rem;
                vertical-align: middle;
            }

            .t-badge {
                padding: 3px 9px;
                border-radius: 20px;
                font-size: 0.72rem;
                font-weight: 600;
                display: inline-block;
                margin: 2px 1px;
            }

            .empty-state {
                text-align: center;
                padding: 52px 20px;
                color: #94a3b8;
            }

                .empty-state i {
                    font-size: 2.4rem;
                    margin-bottom: 12px;
                    display: block;
                    color: #cbd5e1;
                }

            .table-responsive {
                width: 100%;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

                .table-responsive table {
                    min-width: 800px;
                }

            /* Footer */
            .app-footer {
                background: white;
                border-top: 1px solid #e2e8f0;
                padding: 12px 28px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                font-size: 0.72rem;
                color: #94a3b8;
            }

            /* Responsive */
            @@media (max-width: 900px) {
                .app-sidebar {
                    width: 60px;
                }

                .sidebar-link span, .sidebar-section-label {
                    display: none;
                }

                .sidebar-link {
                    justify-content: center;
                    padding: 10px;
                }

                .sidebar-brand {
                    padding: 14px 10px;
                    justify-content: center;
                }

                    .sidebar-brand img {
                        width: 36px;
                    }
            }

            @@media (max-width: 768px) {
                .form-grid {
                    grid-template-columns: 1fr;
                }

                .form-actions {
                    grid-column: span 1;
                }
            }
    </style>
</head>
<body>
    <div class="app-shell">

        <!-- ══ SIDEBAR ══ -->
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <img src="/image/logo.png" alt="College Logo" />
            </div>

            <nav class="sidebar-nav">
                <a href="/Feedback/FeedbackDashboard" class="sidebar-link">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Feedback/ManageTeachers" class="sidebar-link active">
                    <i class="fas fa-users-cog"></i>
                    <span>Manage Teachers</span>
                </a>

                <span class="sidebar-section-label">Teachers</span>
                <a href="/Feedback/TeachersList" class="sidebar-link">
                    <i class="fas fa-user-graduate"></i>
                    <span>Teachers List</span>
                </a>

                <span class="sidebar-section-label">Reports</span>
                <a href="/Feedback/ExportFeedback" class="sidebar-link">
                    <i class="fas fa-download"></i>
                    <span>Export CSV</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/Feedback/FeedbackLogout" class="sidebar-link danger">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back to Portal</span>
                </a>
            </div>
        </aside>
        <a href="c:\users\nirmal\source\repos\feedback_system\views\feedback\submitfeedback.cshtml">c:\users\nirmal\source\repos\feedback_system\views\feedback\submitfeedback.cshtml</a>

        <!-- ══ MAIN ══ -->
        <div class="app-main"> 

            <!-- Top Bar -->
            <div class="app-topbar">
                <div class="topbar-title-block">
                    <div class="page-title">
                        <i class="fas fa-users-cog"></i>
                        Manage Teachers
                    </div>
                    <div class="page-sub">Texas College of Management &amp; IT</div>
                </div>
                <div class="topbar-right">
                    <div class="topbar-user">
                        <div class="user-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="user-info-text">
                            <div class="user-name">Texas College of</div>
                            <div class="user-role">Management &amp; IT</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="app-content">
                <div class="container">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i>
                            @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-error">
                            <i class="fas fa-exclamation-triangle"></i>
                            @TempData["Error"]
                        </div>
                    }

                    <div class="add-card">
                        <div class="card-title">
                            <i class="fas fa-user-plus"></i>
                            Add New Teacher
                        </div>
                        <form asp-controller="Feedback" asp-action="AddTeacher" method="post">
                            @Html.AntiForgeryToken()
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Full Name *</label>
                                    <input type="text" name="FullName" placeholder="Full Name" required />
                                </div>
                                <div class="form-group">
                                    <label>Subject *</label>
                                    <input type="text" name="Subject" placeholder="Subject" required />
                                </div>

                                <!-- Pop-up Semester Dropdown -->
                                <div class="form-group">
                                    <label>Semesters *</label>
                                    <div class="custom-dropdown" id="semesterDropdown">
                                        <button type="button" class="dropdown-btn" onclick="toggleDropdown('semesterDropdownOptions')">
                                            <span class="btn-text">Select Semesters</span>
                                            <i class="fas fa-chevron-down"></i>
                                        </button>
                                        <div class="dropdown-options" id="semesterDropdownOptions">
                                            <label class="checkbox-label master-label">
                                                <input type="checkbox" id="allSemesters" onchange="toggleSelectAll('semesterDropdownOptions', this)">
                                                <strong>All Semesters</strong>
                                            </label>
                                            <hr class="dropdown-divider" />
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="1st Semester" onchange="updateDropdownText('semesterDropdown')"> 1st Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="2nd Semester" onchange="updateDropdownText('semesterDropdown')"> 2nd Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="3rd Semester" onchange="updateDropdownText('semesterDropdown')"> 3rd Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="4th Semester" onchange="updateDropdownText('semesterDropdown')"> 4th Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="5th Semester" onchange="updateDropdownText('semesterDropdown')"> 5th Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="6th Semester" onchange="updateDropdownText('semesterDropdown')"> 6th Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="7th Semester" onchange="updateDropdownText('semesterDropdown')"> 7th Sem</label>
                                            <label class="checkbox-label"><input type="checkbox" name="Semesters" value="8th Semester" onchange="updateDropdownText('semesterDropdown')"> 8th Sem</label>
                                        </div>
                                    </div>
                                </div>

                                <!-- Pop-up Section Dropdown -->
                                <div class="form-group">
                                    <label>Sections *</label>
                                    <div class="custom-dropdown" id="sectionDropdown">
                                        <button type="button" class="dropdown-btn" onclick="toggleDropdown('sectionDropdownOptions')">
                                            <span class="btn-text">Select Sections</span>
                                            <i class="fas fa-chevron-down"></i>
                                        </button>
                                        <div class="dropdown-options" id="sectionDropdownOptions">
                                            <label class="checkbox-label master-label">
                                                <input type="checkbox" id="allSections" onchange="toggleSelectAll('sectionDropdownOptions', this)">
                                                <strong>All Sections</strong>
                                            </label>
                                            <hr class="dropdown-divider" />
                                            @foreach (var letter in new char[] { 'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J' })
                                            {
                                                <label class="checkbox-label">
                                                    <input type="checkbox" name="Sections" value="@letter" onchange="updateDropdownText('sectionDropdown')"> Section @letter
                                                </label>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Designation</label>
                                    <input type="text" name="Designation" placeholder="Designation (e.g. Lecturer)" />
                                </div>

                                <div class="form-actions">
                                    <button type="submit" class="btn btn-indigo">
                                        <i class="fas fa-plus"></i> Add Teacher
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="table-card">
                        <div class="table-top">
                            <h2>
                                <i class="fas fa-list"></i>
                                All Teachers
                            </h2>
                            <div class="table-controls">
                                <div class="search-wrapper">
                                    <i class="fas fa-search"></i>
                                    <input type="text" id="teacherSearch" class="search-input" placeholder="Search teacher name..." onkeyup="filterTeachers()" />
                                </div>
                                <span id="teacherCount">@Model.Count teacher@(Model.Count != 1 ? "s" : "")</span>
                            </div>
                        </div>

                        @if (Model.Any())
                        {
                            <div class="table-responsive">
                                <table id="teachersTable">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Name</th>
                                            <th>Subject</th>
                                            <th>Semester</th>
                                            <th>Section</th>
                                            <th>Designation</th>
                                            <th>Added</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var t in Model)
                                        {
                                            <tr class="teacher-row">
                                                <td style="color:#94a3b8;font-size:0.8rem;">@t.Id</td>
                                                <td>
                                                    <div class="teacher-name" style="font-weight:600;color:#0f172a;">@t.FullName</div>
                                                </td>
                                                <td style="color:#475569;">@t.Subject</td>
                                                <td>
                                                    <span class="t-badge" style="background:#f3e8ff;color:#a855f7;">
                                                        @t.Semester
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="t-badge" style="background:#eff6ff;color:#2563eb;">
                                                        @(string.IsNullOrEmpty(t.ProfessionalClass) ? "—" : t.ProfessionalClass)
                                                    </span>
                                                </td>
                                                <td style="color:#64748b;">@(t.Designation ?? "—")</td>
                                                <td style="color:#94a3b8;font-size:0.8rem;">
                                                    @t.CreatedAt.ToString("dd MMM yyyy")
                                                </td>
                                                <td>
                                                    <div style="display:flex;gap:8px;align-items:center;">
                                                        <a href="/Feedback/TeacherDetail/@t.Id" class="btn btn-outline" style="padding:5px 12px;font-size:0.78rem;">
                                                            <i class="fas fa-eye"></i> View
                                                        </a>
                                                        <form method="post" asp-controller="Feedback" asp-action="DeleteTeacher" style="display:inline;" onsubmit="return confirm('Remove @t.FullName from the system?')">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@t.Id" />
                                                            <button type="submit" class="btn btn-red" style="padding:5px 12px;font-size:0.78rem;">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="fas fa-user-slash"></i>
                                <p style="font-size:0.94rem;font-weight:600;color:#475569;">
                                    No teachers added yet
                                </p>
                                <p style="font-size:0.82rem;margin-top:4px;">
                                    Use the form above to add your first teacher
                                </p>
                            </div>
                        }
                    </div>

                </div><!-- /container -->
            </div><!-- /app-content -->
            <!-- Footer -->
            <div class="app-footer">
                <span>© 2026 Texas International College. All rights reserved.</span>
                <span>Version 1.0.0</span>
            </div>

        </div><!-- /app-main -->
    </div><!-- /app-shell -->
    <!-- Interactive Dropdown & Table Search Logic -->
    <script>
            // Toggle specific custom dropdown display
            function toggleDropdown(id) {
                document.querySelectorAll('.dropdown-options').forEach(el => {
                    if (el.id !== id) el.classList.remove('show');
                });
                document.getElementById(id).classList.toggle('show');
            }

            // Close UI windows automatically when user clicks anywhere outside
            window.onclick = function(event) {
                if (!event.target.closest('.custom-dropdown')) {
                    document.querySelectorAll('.dropdown-options').forEach(el => {
                        el.classList.remove('show');
                    });
                }
            }

            // Handles the "All" options check toggle state changes
            function toggleSelectAll(containerId, masterCheckbox) {
                const container = document.getElementById(containerId);
                const checkboxes = container.querySelectorAll('input[type="checkbox"]:not(.master-label input)');

                checkboxes.forEach(cb => {
                    cb.checked = masterCheckbox.checked;
                });

                updateDropdownText(container.parentElement.id);
            }

            // Dynamically updates UI header summary within select controls
            function updateDropdownText(dropdownId) {
                const dropdown = document.getElementById(dropdownId);
                const checkboxes = dropdown.querySelectorAll('.dropdown-options input[type="checkbox"]:not(.master-label input)');
                const masterCheckbox = dropdown.querySelector('.master-label input');
                const checkedBoxes = Array.from(checkboxes).filter(cb => cb.checked);
                const buttonText = dropdown.querySelector('.btn-text');

                if (masterCheckbox) {
                    masterCheckbox.checked = (checkedBoxes.length === checkboxes.length);
                }

                if (checkedBoxes.length === 0) {
                    buttonText.innerText = dropdownId === 'semesterDropdown' ? 'Select Semesters' : 'Select Sections';
                } else if (checkedBoxes.length === checkboxes.length) {
                    buttonText.innerText = dropdownId === 'semesterDropdown' ? 'All Semesters Selected' : 'All Sections Selected';
                } else if (checkedBoxes.length <= 2) {
                    buttonText.innerText = checkedBoxes.map(cb => cb.parentElement.innerText.trim()).join(', ');
                } else {
                    buttonText.innerText = checkedBoxes.length + " Items Selected";
                }
            }

            // Client-side quick filter logic
            function filterTeachers() {
                var input = document.getElementById("teacherSearch");
                var filter = input.value.toLowerCase();
                var table = document.getElementById("teachersTable");
                if (!table) return;

                var rows = table.getElementsByClassName("teacher-row");
                var visibleCount = 0;

                for (var i = 0; i < rows.length; i++) {
                    var nameContainer = rows[i].getElementsByClassName("teacher-name")[0];
                    if (nameContainer) {
                        var nameText = nameContainer.textContent || nameContainer.innerText;
                        if (nameText.toLowerCase().indexOf(filter) > -1) {
                            rows[i].style.display = "";
                            visibleCount++;
                        } else {
                            rows[i].style.display = "none";
                        }
                    }
                }

                var counter = document.getElementById("teacherCount");
                counter.innerText = visibleCount + " teacher" + (visibleCount !== 1 ? "s" : "") + " found";
            }
    </script>
</body>
</html>