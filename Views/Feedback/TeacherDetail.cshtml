@model List<CollegeIssueManagement.Models.TeacherFeedback>
@{
    Layout = null;

    // Fallbacks for aggregated counts sent from Controller
    int totalCount = ViewBag.TotalCount ?? 0;
    int excellentCount = ViewBag.ExcellentCount ?? 0;
    int goodCount = ViewBag.GoodCount ?? 0;
    int averageCount = ViewBag.AverageCount ?? 0;
    int belowAvgCount = ViewBag.BelowAvgCount ?? 0;

    // Calculate percentage breakdown for the visual graphs
    double excPct = totalCount > 0 ? Math.Round((double)excellentCount / totalCount * 100) : 0;
    double goodPct = totalCount > 0 ? Math.Round((double)goodCount / totalCount * 100) : 0;
    double avgPct = totalCount > 0 ? Math.Round((double)averageCount / totalCount * 100) : 0;
    double bAvgPct = totalCount > 0 ? Math.Round((double)belowAvgCount / totalCount * 100) : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Teacher Detail - @ViewBag.TeacherName</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f8fafc;
                color: #0f172a;
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            /* ══════════════════════════════
                         SIDEBAR — matches ManageTeachers
                      ══════════════════════════════ */
            .app-sidebar {
                width: 220px;
                background-color: #0a1628;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                position: sticky;
                top: 0;
                height: 100vh;
                overflow: hidden;
            }

                .app-sidebar::after {
                    content: '';
                    position: absolute;
                    top: 55%;
                    left: -40px;
                    width: 290px;
                    height: 290px;
                    background-image: url('/image/sidelogo.png');
                    background-size: contain;
                    background-repeat: no-repeat;
                    background-position: top left;
                    opacity: 0.92;
                    pointer-events: none;
                    z-index: 0;
                }

            .sidebar-brand {
                padding: 16px 14px 14px;
                display: flex;
                flex-direction: column;
                align-items: center;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                position: relative;
                z-index: 2;
            }

                .sidebar-brand img {
                    width: 160px;
                    height: auto;
                    object-fit: contain;
                }

            .sidebar-nav {
                flex: 1;
                padding: 12px 10px;
                display: flex;
                flex-direction: column;
                gap: 2px;
                position: relative;
                z-index: 2;
                overflow-y: auto;
            }

                .sidebar-nav::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar-nav::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar-nav::-webkit-scrollbar-thumb {
                    background: #1e293b;
                    border-radius: 2px;
                }

            .sidebar-section-label {
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: #e879a0;
                padding: 14px 8px 5px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 12px;
                border-radius: 10px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 500;
                transition: all 0.15s ease;
                position: relative;
            }

                .sidebar-link i {
                    font-size: 0.85rem;
                    width: 16px;
                    text-align: center;
                    flex-shrink: 0;
                }

                .sidebar-link:hover {
                    background: rgba(255,255,255,0.07);
                    color: #e2e8f0;
                    text-decoration: none;
                }

                .sidebar-link.active {
                    background: linear-gradient(135deg, #e879f9, #a855f7);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 14px rgba(168,85,247,0.4);
                }

                    .sidebar-link.active i {
                        color: #ffffff;
                    }

                .sidebar-link.danger {
                    color: #cbd5e1;
                }

                    .sidebar-link.danger:hover {
                        color: #f8fafc;
                        background: rgba(255,255,255,0.07);
                    }

            .sidebar-divider {
                height: 1px;
                background: rgba(255,255,255,0.05);
                margin: 4px 8px;
            }

            .sidebar-footer {
                padding: 10px 10px 14px;
                border-top: 1px solid rgba(255,255,255,0.05);
                position: relative;
                z-index: 2;
            }

            /* ── Main Layout ── */
            .app-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .app-topbar {
                height: 54px;
                background: white;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 24px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topbar-title {
                font-size: 0.94rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .topbar-title i {
                    color: #6366f1;
                }

            .app-content {
                flex: 1;
                padding: 22px 24px;
            }

            .container {
                max-width: 1100px;
                margin: 0 auto;
            }

            /* ── Profile & Summary Section ── */
            .profile-banner {
                background: white;
                border-radius: 14px;
                padding: 24px;
                border: 1px solid #e2e8f0;
                margin-bottom: 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 20px;
            }

            .profile-info {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .profile-avatar {
                width: 60px;
                height: 60px;
                border-radius: 14px;
                background: linear-gradient(135deg, #6366f1, #8b5cf6);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1.6rem;
            }

            .profile-name {
                font-size: 1.25rem;
                font-weight: 700;
                color: #0f172a;
            }

            .profile-meta {
                font-size: 0.85rem;
                color: #64748b;
                margin-top: 4px;
                display: flex;
                gap: 12px;
            }

                .profile-meta span i {
                    margin-right: 4px;
                    color: #6366f1;
                }

            /* ── Analytics Layout ── */
            .analytics-row {
                display: grid;
                grid-template-columns: 1fr 2fr;
                gap: 20px;
                margin-bottom: 24px;
            }

            .metric-card {
                background: white;
                border-radius: 14px;
                padding: 24px;
                border: 1px solid #e2e8f0;
                text-align: center;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .metric-value {
                font-size: 3rem;
                font-weight: 800;
                color: #0f172a;
                line-height: 1;
            }

            .metric-label {
                font-size: 0.85rem;
                color: #64748b;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-top: 8px;
            }

            .distribution-card {
                background: white;
                border-radius: 14px;
                padding: 24px;
                border: 1px solid #e2e8f0;
            }

            .dist-title {
                font-size: 0.95rem;
                font-weight: 700;
                margin-bottom: 16px;
                color: #334155;
            }

            .dist-item {
                margin-bottom: 12px;
            }

                .dist-item:last-child {
                    margin-bottom: 0;
                }

            .dist-info {
                display: flex;
                justify-content: space-between;
                font-size: 0.82rem;
                font-weight: 600;
                color: #475569;
                margin-bottom: 4px;
            }

            .progress-bar-container {
                height: 8px;
                background: #f1f5f9;
                border-radius: 100px;
                overflow: hidden;
            }

            .progress-bar-fill {
                height: 100%;
                border-radius: 100px;
                transition: width 0.3s ease;
            }

            /* ── Comments Feed ── */
            .feed-card {
                background: white;
                border-radius: 14px;
                border: 1px solid #e2e8f0;
                padding: 24px;
            }

            .feed-title {
                font-size: 1rem;
                font-weight: 700;
                color: #0f172a;
                margin-bottom: 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .feed-title i {
                    color: #6366f1;
                }

            .comment-item {
                padding: 16px;
                border-radius: 10px;
                background: #f8fafc;
                border: 1px solid #f1f5f9;
                margin-bottom: 12px;
            }

                .comment-item:last-child {
                    margin-bottom: 0;
                }

            .comment-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 8px;
            }

            .badge-rating {
                padding: 4px 10px;
                border-radius: 20px;
                font-size: 0.72rem;
                font-weight: 700;
                text-transform: uppercase;
            }

            .rating-excellent {
                background: #dcfce7;
                color: #16a34a;
            }

            .rating-good {
                background: #dbeafe;
                color: #2563eb;
            }

            .rating-average {
                background: #fef9c3;
                color: #ca8a04;
            }

            .rating-below {
                background: #fee2e2;
                color: #dc2626;
            }

            .comment-date {
                font-size: 0.75rem;
                color: #94a3b8;
            }

            .comment-text {
                font-size: 0.88rem;
                color: #334155;
                line-height: 1.5;
            }

            .empty-comments {
                text-align: center;
                padding: 40px 20px;
                color: #94a3b8;
                font-size: 0.88rem;
            }

                .empty-comments i {
                    font-size: 2rem;
                    color: #cbd5e1;
                    margin-bottom: 8px;
                    display: block;
                }

            .btn-back {
                background: #ede9fe;
                color: #6366f1;
                padding: 8px 16px;
                border-radius: 8px;
                text-decoration: none;
                font-size: 0.84rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                transition: all 0.15s;
            }

                .btn-back:hover {
                    background: #6366f1;
                    color: white;
                }

            /* ── Responsive ── */
            @@media (max-width: 900px) {
                .app-sidebar {
                    width: 60px;
                }

                .sidebar-link span, .sidebar-section-label {
                    display: none;
                }

                .sidebar-link {
                    justify-content: center;
                    padding: 10px;
                }

                .sidebar-brand {
                    padding: 14px 10px;
                    justify-content: center;
                }

                    .sidebar-brand img {
                        width: 36px;
                    }
            }

            @@media (max-width: 768px) {
                .analytics-row {
                    grid-template-columns: 1fr;
                }
            }
    </style>
</head>
<body>
    <div class="app-shell">

        <!-- ══ SIDEBAR ══ -->
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <img src="/image/logo.png" alt="College Logo" />
            </div>

            <nav class="sidebar-nav">
                <a href="/Feedback/FeedbackDashboard" class="sidebar-link">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Feedback/ManageTeachers" class="sidebar-link">
                    <i class="fas fa-users-cog"></i>
                    <span>Manage Teachers</span>
                </a>

                <span class="sidebar-section-label">Teachers</span>
                <a href="/Feedback/TeachersList" class="sidebar-link active">
                    <i class="fas fa-user-graduate"></i>
                    <span>Teachers List</span>
                </a>

                <span class="sidebar-section-label">Reports</span>
                <a href="/Feedback/ExportFeedback" class="sidebar-link">
                    <i class="fas fa-download"></i>
                    <span>Export CSV</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/Feedback/FeedbackLogout" class="sidebar-link danger">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back to Portal</span>
                </a>
            </div>
        </aside>

        <!-- ══ MAIN ══ -->
        <div class="app-main">
            <div class="app-topbar">
                <div class="topbar-title">
                    <i class="fas fa-eye"></i>
                    Feedback Profile Detailed Breakdown
                </div>
                <a href="/Feedback/TeachersList" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>

            <div class="app-content">
                <div class="container">

                    <!-- ── Teacher Info Header Banner ── -->
                    <div class="profile-banner">
                        <div class="profile-info">
                            <div class="profile-avatar">
                                <i class="fas fa-user-tie"></i>
                            </div>
                            <div>
                                <h1 class="profile-name">@ViewBag.TeacherName</h1>
                                <div class="profile-meta">
                                    <span><i class="fas fa-book"></i> @ViewBag.Subject</span>
                                    <span><i class="fas fa-graduation-cap"></i> Semester @ViewBag.Semester</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── Analytics Row ── -->
                    <div class="analytics-row">
                        <div class="metric-card">
                            <div class="metric-value">@totalCount</div>
                            <div class="metric-label">Total Submissions</div>
                        </div>

                        <div class="distribution-card">
                            <h2 class="dist-title">Rating Breakdown</h2>

                            <div class="dist-item">
                                <div class="dist-info">
                                    <span>Excellent</span>
                                    <span>@excellentCount (@excPct%)</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: @excPct%; background-color: #16a34a;"></div>
                                </div>
                            </div>

                            <div class="dist-item">
                                <div class="dist-info">
                                    <span>Good</span>
                                    <span>@goodCount (@goodPct%)</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: @goodPct%; background-color: #2563eb;"></div>
                                </div>
                            </div>

                            <div class="dist-item">
                                <div class="dist-info">
                                    <span>Average</span>
                                    <span>@averageCount (@avgPct%)</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: @avgPct%; background-color: #ca8a04;"></div>
                                </div>
                            </div>

                            <div class="dist-item">
                                <div class="dist-info">
                                    <span>Below Average</span>
                                    <span>@belowAvgCount (@bAvgPct%)</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: @bAvgPct%; background-color: #dc2626;"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── Comments Feed ── -->
                    <div class="feed-card">
                        <h2 class="feed-title">
                            <i class="far fa-comments"></i> Student Responses &amp; Remarks
                        </h2>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var feedback in Model)
                            {
                                string cssClass = "rating-average";
                                if (feedback.Rating == "Excellent") cssClass = "rating-excellent";
                                else if (feedback.Rating == "Good") cssClass = "rating-good";
                                else if (feedback.Rating == "Below Average") cssClass = "rating-below";

                                <div class="comment-item">
                                    <div class="comment-header">
                                        <span class="badge-rating @cssClass">@feedback.Rating</span>
                                        <span class="comment-date">
                                            <i class="far fa-clock"></i>
                                            @feedback.SubmittedDate.ToString("MMMM dd, yyyy")
                                        </span>
                                    </div>
                                    <p class="comment-text">
                                        @(string.IsNullOrWhiteSpace(feedback.FeedbackText) ? "No remarks provided." : feedback.FeedbackText)
                                    </p>
                                    <div style="font-size:0.75rem;color:#64748b;margin-top:6px;">
                                        <i class="fas fa-user"></i> By: @(feedback.IsAnonymous ? "Anonymous Student" : feedback.StudentName)
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-comments">
                                <i class="fas fa-comment-slash"></i>
                                No evaluation remarks recorded for this instructor yet.
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</body>
</html>