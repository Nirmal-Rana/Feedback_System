@model List<CollegeIssueManagement.Models.TeacherSemesterRow>

@{
    Layout = null;
    var counts = ViewBag.FeedbackCounts as Dictionary<int, dynamic> ?? new Dictionary<int, dynamic>();
    string semester = ViewBag.Semester as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@semester — Teachers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f0f2f8;
                color: #0f172a;
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            .app-sidebar {
                width: 220px;
                background-color: #0a1628;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                position: sticky;
                top: 0;
                height: 100vh;
                overflow: hidden;
            }

                .app-sidebar::after {
                    content: '';
                    position: absolute;
                    top: 55%;
                    left: -40px;
                    width: 290px;
                    height: 290px;
                    background-image: url('/image/sidelogo.png');
                    background-size: contain;
                    background-repeat: no-repeat;
                    background-position: top left;
                    opacity: 0.92;
                    pointer-events: none;
                    z-index: 0;
                }

            .sidebar-brand {
                padding: 16px 14px 14px;
                display: flex;
                flex-direction: column;
                align-items: center;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                position: relative;
                z-index: 2;
            }

                .sidebar-brand img {
                    width: 160px;
                    height: auto;
                    object-fit: contain;
                }

            .sidebar-nav {
                flex: 1;
                padding: 12px 10px;
                display: flex;
                flex-direction: column;
                gap: 2px;
                position: relative;
                z-index: 2;
                overflow-y: auto;
            }

                .sidebar-nav::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar-nav::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar-nav::-webkit-scrollbar-thumb {
                    background: #1e293b;
                    border-radius: 2px;
                }

            .sidebar-section-label {
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: #e879a0;
                padding: 14px 8px 5px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 12px;
                border-radius: 10px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 500;
                transition: all 0.15s ease;
                position: relative;
            }

                .sidebar-link i {
                    font-size: 0.85rem;
                    width: 16px;
                    text-align: center;
                    flex-shrink: 0;
                }

                .sidebar-link:hover {
                    background: rgba(255,255,255,0.07);
                    color: #e2e8f0;
                    text-decoration: none;
                }

                .sidebar-link.active {
                    background: linear-gradient(135deg, #e879f9, #a855f7);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 14px rgba(168,85,247,0.4);
                }

                    .sidebar-link.active i {
                        color: #ffffff;
                    }

                .sidebar-link.danger {
                    color: #cbd5e1;
                }

                    .sidebar-link.danger:hover {
                        color: #f8fafc;
                        background: rgba(255,255,255,0.07);
                    }

            .sidebar-footer {
                padding: 10px 10px 14px;
                border-top: 1px solid rgba(255,255,255,0.05);
                position: relative;
                z-index: 2;
            }

            .app-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
                background: #f0f2f8;
            }

            .app-topbar {
                height: 64px;
                background: white;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topbar-title-block .page-title {
                font-size: 1.05rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .topbar-title-block .page-title i {
                    color: #e879f9;
                }

            .topbar-title-block .page-sub {
                font-size: 0.72rem;
                color: #64748b;
                margin-top: 1px;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 14px;
            }

            .topbar-user {
                display: flex;
                align-items: center;
                gap: 9px;
                padding: 5px 10px 5px 5px;
                border-radius: 24px;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                cursor: pointer;
            }

            .user-avatar {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: linear-gradient(135deg, #e879f9, #a855f7);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 0.85rem;
            }

            .user-info-text .user-name {
                font-size: 0.75rem;
                font-weight: 600;
                color: #0f172a;
                line-height: 1.2;
            }

            .user-info-text .user-role {
                font-size: 0.65rem;
                color: #64748b;
            }

            .app-content {
                flex: 1;
                padding: 22px 24px;
            }

            .container {
                max-width: 1000px;
                margin: 0 auto;
            }

            .page-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 20px;
                flex-wrap: wrap;
                gap: 12px;
            }

            .page-heading {
                font-size: 1.05rem;
                font-weight: 700;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .page-heading i {
                    color: #e879f9;
                }

            .page-sub {
                font-size: 0.8rem;
                color: #64748b;
                margin-top: 3px;
            }

            .btn {
                padding: 8px 16px;
                border-radius: 8px;
                font-size: 0.83rem;
                font-weight: 600;
                cursor: pointer;
                border: none;
                display: inline-flex;
                align-items: center;
                gap: 7px;
                text-decoration: none;
                transition: all 0.15s;
            }

            .btn-outline {
                background: white;
                color: #475569;
                border: 1px solid #cbd5e1;
            }

                .btn-outline:hover {
                    background: #f8fafc;
                    color: #0f172a;
                }

            /* ── Teacher rows ── */
            .teacher-list {
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            .t-row {
                background: white;
                border-radius: 14px;
                padding: 16px 20px;
                border: 1px solid #e8edf5;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
                text-decoration: none;
                color: inherit;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
                transition: all 0.18s;
                position: relative;
                overflow: hidden;
                flex-wrap: wrap;
            }

                .t-row::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    bottom: 0;
                    width: 4px;
                    background: linear-gradient(180deg, #e879f9, #a855f7);
                    opacity: 0;
                    transition: opacity 0.18s;
                }

                .t-row:hover {
                    transform: translateX(3px);
                    box-shadow: 0 8px 20px rgba(168,85,247,0.12);
                    border-color: #c4b5fd;
                    color: inherit;
                }

                    .t-row:hover::before {
                        opacity: 1;
                    }

            .t-row-left {
                display: flex;
                align-items: center;
                gap: 14px;
                min-width: 240px;
            }

            .t-avatar {
                width: 48px;
                height: 48px;
                border-radius: 12px;
                background: linear-gradient(135deg, #fce7f3, #ede9fe);
                display: flex;
                align-items: center;
                justify-content: center;
                color: #a855f7;
                font-size: 1.2rem;
                flex-shrink: 0;
                overflow: hidden;
            }

                .t-avatar img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .t-name {
                font-size: 0.94rem;
                font-weight: 700;
                color: #0f172a;
            }

            .t-sub {
                font-size: 0.76rem;
                color: #64748b;
                margin-top: 2px;
            }

            .t-badges {
                display: flex;
                gap: 5px;
                flex-wrap: wrap;
            }

            .t-badge {
                padding: 3px 9px;
                border-radius: 20px;
                font-size: 0.71rem;
                font-weight: 600;
                display: inline-block;
                white-space: nowrap;
            }

            .t-row-right {
                display: flex;
                align-items: center;
                gap: 22px;
            }

            .t-stat {
                text-align: center;
                min-width: 52px;
            }

            .t-stat-val {
                font-size: 1.1rem;
                font-weight: 700;
                color: #0f172a;
            }

            .t-stat-lbl {
                font-size: 0.63rem;
                color: #94a3b8;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.4px;
                margin-top: 1px;
            }

            .t-view-btn {
                padding: 7px 16px;
                border-radius: 7px;
                background: #f3e8ff;
                color: #a855f7;
                font-size: 0.79rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: 5px;
                text-decoration: none;
                transition: all 0.15s;
                white-space: nowrap;
            }

                .t-view-btn:hover {
                    background: linear-gradient(135deg, #e879f9, #a855f7);
                    color: white;
                }

            .empty-state {
                text-align: center;
                padding: 64px 20px;
                color: #94a3b8;
                background: white;
                border-radius: 14px;
                border: 1px solid #e8edf5;
            }

                .empty-state i {
                    font-size: 2.8rem;
                    margin-bottom: 14px;
                    display: block;
                    color: #cbd5e1;
                }

            .app-footer {
                background: white;
                border-top: 1px solid #e2e8f0;
                padding: 12px 28px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                font-size: 0.72rem;
                color: #94a3b8;
            }

            @@media (max-width: 900px) {
                .app-sidebar {
                    width: 60px;
                }

                .sidebar-link span, .sidebar-section-label {
                    display: none;
                }

                .sidebar-link {
                    justify-content: center;
                    padding: 10px;
                }

                .sidebar-brand {
                    padding: 14px 10px;
                    justify-content: center;
                }

                    .sidebar-brand img {
                        width: 36px;
                    }
            }

            @@media (max-width: 700px) {
                .t-row {
                    flex-direction: column;
                    align-items: flex-start;
                }

                .t-row-right {
                    width: 100%;
                    justify-content: space-between;
                }
            }
    </style>
</head>
<body>
    <div class="app-shell">

        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <img src="/image/logo.png" alt="College Logo" />
            </div>

            <nav class="sidebar-nav">
                <a href="/Feedback/FeedbackDashboard" class="sidebar-link">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Feedback/ManageTeachers" class="sidebar-link">
                    <i class="fas fa-users-cog"></i>
                    <span>Manage Teachers</span>
                </a>

                <span class="sidebar-section-label">Teachers</span>
                <a href="/Feedback/TeachersList" class="sidebar-link active">
                    <i class="fas fa-user-graduate"></i>
                    <span>Teachers List</span>
                </a>

                <span class="sidebar-section-label">Reports</span>
                <a href="/Feedback/ExportFeedback" class="sidebar-link">
                    <i class="fas fa-download"></i>
                    <span>Export CSV</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/Feedback/FeedbackLogout" class="sidebar-link danger">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back to Portal</span>
                </a>
            </div>
        </aside>

        <div class="app-main">

            <div class="app-topbar">
                <div class="topbar-title-block">
                    <div class="page-title">
                        <i class="fas fa-graduation-cap"></i>
                        @semester
                    </div>
                    <div class="page-sub">Texas College of Management &amp; IT</div>
                </div>
                <div class="topbar-right">
                    <div class="topbar-user">
                        <div class="user-avatar"><i class="fas fa-user"></i></div>
                        <div class="user-info-text">
                            <div class="user-name">Texas College of</div>
                            <div class="user-role">Management &amp; IT</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container">

                    <div class="page-header">
                        <div>
                            <div class="page-heading">
                                <i class="fas fa-chalkboard-teacher"></i>
                                Teachers — @semester
                            </div>
                            <div class="page-sub">Click a teacher to view their feedback</div>
                        </div>
                        <a href="/Feedback/TeachersList" class="btn btn-outline">
                            <i class="fas fa-arrow-left"></i> Back to Semesters
                        </a>
                    </div>

                    @if (Model.Any())
                    {
                        <div class="teacher-list">
                            @foreach (var t in Model)
                            {
                                dynamic? cnt = counts.ContainsKey(t.Id) ? counts[t.Id] : null;
                                int tCount = cnt != null ? (int)cnt.Count : 0;
                                int tExc = cnt != null ? (int)cnt.Excellent : 0;
                                double pct = tCount > 0 ? Math.Round((double)tExc / tCount * 100) : 0;

                               <a href="/Feedback/TeacherDetail/@t.Id?semester=@Uri.EscapeDataString(semester)" class="t-row">
                                    <div class="t-row-left">
                                        <div class="t-avatar">
                                            @if (!string.IsNullOrEmpty(t.PhotoPath))
                                            {
                                                <img src="@t.PhotoPath" alt="@t.FullName" />
                                            }
                                            else
                                            {
                                                <i class="fas fa-user-tie"></i>
                                            }
                                        </div>
                                        <div>
                                            <div class="t-name">@t.FullName</div>
                                            <div class="t-sub">@t.Subject</div>
                                        </div>
                                    </div>

                                    <div class="t-badges">
                                        @if (!string.IsNullOrEmpty(t.Section))
                                        {
                                            <span class="t-badge" style="background:#eff6ff;color:#2563eb;">
                                                @t.Section
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(t.Designation))
                                        {
                                            <span class="t-badge" style="background:#f8fafc;color:#475569;border:1px solid #e2e8f0;">
                                                @t.Designation
                                            </span>
                                        }
                                    </div>

                                    <div class="t-row-right">
                                        <div class="t-stat">
                                            <div class="t-stat-val">@tCount</div>
                                            <div class="t-stat-lbl">Feedbacks</div>
                                        </div>
                                        @if (tCount > 0)
                                        {
                                            <div class="t-stat">
                                                <div class="t-stat-val" style="color:#16a34a;">@pct%</div>
                                                <div class="t-stat-lbl">Excellent</div>
                                            </div>
                                        }
                                        <span class="t-view-btn">
                                            <i class="fas fa-eye"></i> View
                                        </span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-chalkboard-teacher"></i>
                            <p style="font-size:1rem;font-weight:600;color:#475569;margin-bottom:6px;">
                                No teachers assigned to this semester
                            </p>
                            <a href="/Feedback/ManageTeachers"
                               style="display:inline-flex;align-items:center;gap:7px;margin-top:16px;
                                padding:9px 20px;background:linear-gradient(135deg,#e879f9,#a855f7);
                                color:white;border-radius:8px;font-size:0.84rem;
                                font-weight:600;text-decoration:none;">
                                <i class="fas fa-plus"></i> Add a Teacher
                            </a>
                        </div>
                    }

                </div>
            </div>

            <div class="app-footer">
                <span>© 2026 Texas International College. All rights reserved.</span>
                <span>Version 1.0.0</span>
            </div>

        </div>
    </div>
</body>
</html>