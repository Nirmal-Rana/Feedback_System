@model CollegeIssueManagement.Models.DashboardViewModel
@using CollegeIssueManagement.Models

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* ── Stats Row ── */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: all 0.25s ease;
        text-decoration: none;
        color: inherit;
        border: 2px solid transparent;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .stat-card::after {
        content: '\f061';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        position: absolute;
        right: 16px;
        bottom: 14px;
        font-size: 0.7rem;
        color: #ddd;
        transition: all 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        text-decoration: none;
        color: inherit;
        box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    }

    .stat-card:hover::after { color: #aaa; right: 12px; }

    .stat-card.total:hover   { border-color: #667eea; }
    .stat-card.pending:hover { border-color: #ffc107; }
    .stat-card.approved:hover{ border-color: #006064; }
    .stat-card.resolved:hover{ border-color: #2e7d32; }
    .stat-card.rejected:hover{ border-color: #dc2626; }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
    }

    .stat-info .stat-number {
        font-size: 1.85rem;
        font-weight: 800;
        color: #222;
        line-height: 1;
    }

    .stat-info .stat-label {
        font-size: 0.78rem;
        color: #999;
        font-weight: 700;
        margin-top: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-hint {
        font-size: 0.72rem;
        color: #bbb;
        margin-top: 3px;
    }

    /* ── Issue Type Cards ── */
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .section-title i { color: #667eea; }

    .type-cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 30px;
    }

    .type-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.07);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
        border-top: 4px solid transparent;
        transition: all 0.25s;
        position: relative;
        overflow: hidden;
    }

    .type-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        text-decoration: none;
    }

    .type-card-icon {
        width: 46px; height: 46px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; color: white;
    }

    .type-card-count { font-size: 1.7rem; font-weight: 800; color: #222; line-height: 1; }
    .type-card-name  { font-size: 0.82rem; font-weight: 700; color: #555; }
    .type-card-sub   { font-size: 0.75rem; color: #aaa; }

    .type-card-arrow {
        position: absolute; top: 16px; right: 16px;
        color: #ddd; font-size: 0.85rem;
    }

    .tc-internet        { border-top-color: #1565c0; }
    .tc-internet .type-card-icon        { background: #1565c0; }
    .tc-idcard          { border-top-color: #6a1b9a; }
    .tc-idcard .type-card-icon          { background: #6a1b9a; }
    .tc-internship      { border-top-color: #2e7d32; }
    .tc-internship .type-card-icon      { background: #2e7d32; }
    .tc-job             { border-top-color: #e65100; }
    .tc-job .type-card-icon             { background: #e65100; }
    .tc-feedback        { border-top-color: #880e4f; }
    .tc-feedback .type-card-icon        { background: #880e4f; }
    .tc-counselling     { border-top-color: #006064; }
    .tc-counselling .type-card-icon     { background: #006064; }
    .tc-management      { border-top-color: #f57f17; }
    .tc-management .type-card-icon      { background: #f57f17; }
    .tc-others          { border-top-color: #424242; }
    .tc-others .type-card-icon          { background: #424242; }

    /* ── Bottom Grid ── */
    .bottom-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 24px;
    }

    .panel-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        overflow: hidden;
    }

    .panel-header {
        padding: 18px 22px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .panel-header h3 { margin: 0; font-size: 0.95rem; color: #333; font-weight: 700; }

    .view-all-link {
        font-size: 0.82rem;
        color: #667eea;
        text-decoration: none;
        font-weight: 600;
    }

    table { width: 100%; border-collapse: collapse; }
    thead th {
        padding: 11px 16px;
        text-align: left;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #aaa;
        font-weight: 700;
        background: #fafafa;
        border-bottom: 1px solid #f0f0f0;
    }
    tbody td {
        padding: 12px 16px;
        font-size: 0.88rem;
        color: #333;
        border-bottom: 1px solid #f8f8f8;
        vertical-align: middle;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #fafbff; }

    .badge { padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; display: inline-block; }
    .badge-pending  { background: #fff3cd; color: #856404; }
    .badge-approved { background: #d1ecf1; color: #0c5460; }
    .badge-resolved { background: #d4edda; color: #155724; }
    .badge-rejected { background: #f8d7da; color: #721c24; }

    .notif-item {
        padding: 14px 22px;
        border-bottom: 1px solid #f5f5f5;
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }
    .notif-item:last-child { border-bottom: none; }

    .notif-dot { width: 8px; height: 8px; border-radius: 50%; background: #667eea; margin-top: 5px; flex-shrink: 0; }
    .notif-dot.read { background: #e0e0e0; }
    .notif-title { font-size: 0.85rem; font-weight: 600; color: #333; margin-bottom: 3px; }
    .notif-time  { font-size: 0.75rem; color: #aaa; }

    @@media (max-width: 1100px) {
        .stats-row      { grid-template-columns: repeat(3, 1fr); }
        .type-cards-grid{ grid-template-columns: repeat(2, 1fr); }
        .bottom-grid    { grid-template-columns: 1fr; }
    }

    @@media (max-width: 600px) {
        .stats-row { grid-template-columns: repeat(2, 1fr); }
    }
</style>

@{
    var rejectedCount = Model.IssuesByType.ContainsKey("Rejected")
        ? Model.IssuesByType["Rejected"] : 0;

    // Get rejected count from issues directly
    var allRejected = Model.RecentIssues.Count == 0 ? 0 :
        Model.TotalIssues - Model.PendingIssues -
        Model.ApprovedIssues - Model.ResolvedIssues;
}

<!-- ── Stats Row — all clickable ── -->
<div class="stats-row">

    <a asp-controller="Admin" asp-action="Issues"
       asp-route-type="all" asp-route-status="all"
       class="stat-card total">
        <div class="stat-icon" style="background:#e8eaff;">
            <i class="fas fa-layer-group" style="color:#667eea;"></i>
        </div>
        <div class="stat-info">
            <div class="stat-number">@Model.TotalIssues</div>
            <div class="stat-label">Total Issues</div>
            <div class="stat-hint">Click to view all</div>
        </div>
    </a>

    <a asp-controller="Admin" asp-action="Issues"
       asp-route-type="all" asp-route-status="Pending"
       class="stat-card pending">
        <div class="stat-icon" style="background:#fff8e1;">
            <i class="fas fa-clock" style="color:#ffc107;"></i>
        </div>
        <div class="stat-info">
            <div class="stat-number">@Model.PendingIssues</div>
            <div class="stat-label">Pending</div>
            <div class="stat-hint">Awaiting review</div>
        </div>
    </a>

    <a asp-controller="Admin" asp-action="Issues"
       asp-route-type="all" asp-route-status="Approved"
       class="stat-card approved">
        <div class="stat-icon" style="background:#e0f7fa;">
            <i class="fas fa-thumbs-up" style="color:#006064;"></i>
        </div>
        <div class="stat-info">
            <div class="stat-number">@Model.ApprovedIssues</div>
            <div class="stat-label">Approved</div>
            <div class="stat-hint">Accepted issues</div>
        </div>
    </a>

    <a asp-controller="Admin" asp-action="Issues"
       asp-route-type="all" asp-route-status="Resolved"
       class="stat-card resolved">
        <div class="stat-icon" style="background:#e8f5e9;">
            <i class="fas fa-check-circle" style="color:#2e7d32;"></i>
        </div>
        <div class="stat-info">
            <div class="stat-number">@Model.ResolvedIssues</div>
            <div class="stat-label">Resolved</div>
            <div class="stat-hint">Completed issues</div>
        </div>
    </a>

    <a asp-controller="Admin" asp-action="Issues"
       asp-route-type="all" asp-route-status="Rejected"
       class="stat-card rejected">
        <div class="stat-icon" style="background:#fff0f0;">
            <i class="fas fa-times-circle" style="color:#dc2626;"></i>
        </div>
        <div class="stat-info">
            <div class="stat-number">
                @(Model.TotalIssues - Model.PendingIssues - Model.ApprovedIssues - Model.ResolvedIssues > 0
                    ? Model.TotalIssues - Model.PendingIssues - Model.ApprovedIssues - Model.ResolvedIssues
                    : 0)
            </div>
            <div class="stat-label">Rejected</div>
            <div class="stat-hint">Declined issues</div>
        </div>
    </a>

</div>

<!-- ── Issue Type Cards ── -->
<p class="section-title">
    <i class="fas fa-th-large"></i> Issues by Type — Click to View
</p>

<div class="type-cards-grid">
    @{
        var typeMap = new[]
        {
            new { Key="Internet",            Label="Internet",       Sub="Connectivity issues",     Icon="fa-wifi",               Css="tc-internet"    },
            new { Key="IDCard",              Label="ID Card",        Sub="Lost / Damaged / New",    Icon="fa-id-card",            Css="tc-idcard"      },
            new { Key="Internship",          Label="Internship",     Sub="Placement guidance",      Icon="fa-briefcase",          Css="tc-internship"  },
            new { Key="JobOpportunity",      Label="Job Opportunity",Sub="Career assistance",       Icon="fa-building",           Css="tc-job"         },
            new { Key="FacultyFeedback",     Label="Faculty Feedback",Sub="Course / Teacher",       Icon="fa-chalkboard-teacher", Css="tc-feedback"    },
            new { Key="Counselling",         Label="Counselling",    Sub="Academic / Personal",     Icon="fa-hands-helping",      Css="tc-counselling" },
            new { Key="ManagementAttention", Label="Management",     Sub="Infrastructure / Policy", Icon="fa-bullhorn",           Css="tc-management"  },
            new { Key="Others",              Label="Others",         Sub="General issues",          Icon="fa-ellipsis-h",         Css="tc-others"      },
        };
    }

    @foreach (var t in typeMap)
    {
        var count = Model.IssuesByType.ContainsKey(t.Key)
            ? Model.IssuesByType[t.Key] : 0;

        <a asp-action="Issues"
           asp-route-type="@t.Key"
           asp-route-status="all"
           class="type-card @t.Css">
            <i class="fas fa-arrow-right type-card-arrow"></i>
            <div class="type-card-icon">
                <i class="fas @t.Icon"></i>
            </div>
            <div class="type-card-count">@count</div>
            <div class="type-card-name">@t.Label</div>
            <div class="type-card-sub">@t.Sub</div>
        </a>
    }
</div>

<!-- ── Bottom: Recent Issues + Notifications ── -->
<div class="bottom-grid">

    <div class="panel-card">
        <div class="panel-header">
            <h3>
                <i class="fas fa-history" style="color:#667eea;margin-right:7px;"></i>
                Recent Issues
            </h3>
            <a asp-action="Issues" class="view-all-link">View All →</a>
        </div>
        @if (Model.RecentIssues.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in Model.RecentIssues)
                    {
                        <tr>
                            <td><strong>#@issue.Id</strong></td>
                            <td>
                                <div style="font-weight:600;font-size:0.88rem;">
                                    @issue.StudentName
                                </div>
                                <div style="font-size:0.75rem;color:#aaa;">
                                    @issue.StudentRollNo
                                </div>
                            </td>
                            <td>
                                <span style="font-size:0.8rem;font-weight:600;color:#555;">
                                    @issue.Type
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-@issue.Status.ToString().ToLower()">
                                    @issue.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="IssueDetails"
                                   asp-route-id="@issue.Id"
                                   style="color:#667eea;font-size:0.82rem;
                                          font-weight:600;text-decoration:none;">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div style="text-align:center;padding:40px 20px;color:#ccc;">
                <i class="fas fa-inbox" style="font-size:2rem;display:block;margin-bottom:10px;"></i>
                No issues submitted yet.
            </div>
        }
    </div>

    <div class="panel-card">
        <div class="panel-header">
            <h3>
                <i class="fas fa-bell" style="color:#667eea;margin-right:7px;"></i>
                Notifications
                @if (Model.UnreadNotifications > 0)
                {
                    <span class="badge badge-pending" style="margin-left:6px;">
                        @Model.UnreadNotifications new
                    </span>
                }
            </h3>
            <a asp-action="Notifications" class="view-all-link">View All →</a>
        </div>

        @if (Model.RecentNotifications.Any())
        {
            @foreach (var n in Model.RecentNotifications)
            {
                <div class="notif-item">
                    <div class="notif-dot @(n.IsRead ? "read" : "")"></div>
                    <div>
                        <div class="notif-title">@n.Title</div>
                        <div class="notif-time">
                            @n.CreatedDate.ToString("dd MMM, hh:mm tt")
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="text-align:center;padding:40px 20px;color:#ccc;">
                <i class="fas fa-bell-slash"
                   style="font-size:2rem;display:block;margin-bottom:10px;"></i>
                No notifications yet.
            </div>
        }
    </div>

</div>