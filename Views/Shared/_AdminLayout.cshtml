<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: #f4f6fb;
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            /* ══════════════════════════════
                         SIDEBAR — matches ManageTeachers
                      ══════════════════════════════ */
            .app-sidebar {
                width: 220px;
                background-color: #0a1628;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                position: sticky;
                top: 0;
                height: 100vh;
                overflow: hidden;
            }

                .app-sidebar::after {
                    content: '';
                    position: absolute;
                    top: 55%;
                    left: -40px;
                    width: 290px;
                    height: 290px;
                    background-image: url('/image/sidelogo.png');
                    background-size: contain;
                    background-repeat: no-repeat;
                    background-position: top left;
                    opacity: 0.92;
                    pointer-events: none;
                    z-index: 0;
                }

            .sidebar-brand {
                padding: 16px 14px 14px;
                display: flex;
                flex-direction: column;
                align-items: center;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                position: relative;
                z-index: 2;
            }

                .sidebar-brand img {
                    width: 160px;
                    height: auto;
                    object-fit: contain;
                }

            .sidebar-nav {
                flex: 1;
                padding: 12px 10px;
                display: flex;
                flex-direction: column;
                gap: 2px;
                position: relative;
                z-index: 2;
                overflow-y: auto;
            }

                .sidebar-nav::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar-nav::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar-nav::-webkit-scrollbar-thumb {
                    background: #1e293b;
                    border-radius: 2px;
                }

            .sidebar-section-label {
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: #e879a0;
                padding: 14px 8px 5px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 12px;
                border-radius: 10px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 500;
                transition: all 0.15s ease;
                position: relative;
            }

                .sidebar-link i {
                    font-size: 0.85rem;
                    width: 16px;
                    text-align: center;
                    flex-shrink: 0;
                }

                .sidebar-link:hover {
                    background: rgba(255,255,255,0.07);
                    color: #e2e8f0;
                    text-decoration: none;
                }

                .sidebar-link.active {
                    background: linear-gradient(135deg, #e879f9, #a855f7);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 14px rgba(168,85,247,0.4);
                }

                    .sidebar-link.active i {
                        color: #ffffff;
                    }

                .sidebar-link.danger {
                    color: #cbd5e1;
                }

                    .sidebar-link.danger:hover {
                        color: #f8fafc;
                        background: rgba(255,255,255,0.07);
                    }

            .sidebar-divider {
                height: 1px;
                background: rgba(255,255,255,0.05);
                margin: 4px 8px;
            }

            .sidebar-footer {
                padding: 10px 10px 14px;
                border-top: 1px solid rgba(255,255,255,0.05);
                position: relative;
                z-index: 2;
            }

            /* ── Main Content ── */
            .app-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .app-topbar {
                height: 58px;
                background: white;
                border-bottom: 1px solid #eee;
                display: flex;
                align-items: center;
                justify-content: flex-end;
                gap: 18px;
                padding: 0 28px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topbar-notif {
                position: relative;
                color: #555;
                font-size: 1.1rem;
                cursor: pointer;
                text-decoration: none;
            }

                .topbar-notif:hover {
                    color: #667eea;
                }

            .topbar-welcome {
                font-size: 0.86rem;
                color: #666;
                display: flex;
                align-items: center;
                gap: 7px;
            }

                .topbar-welcome i {
                    color: #667eea;
                }

            .app-content {
                flex: 1;
                padding: 24px 28px;
            }

            @@media (max-width: 900px) {
                .app-sidebar {
                    width: 60px;
                }

                .sidebar-link span, .sidebar-section-label {
                    display: none;
                }

                .sidebar-link {
                    justify-content: center;
                    padding: 10px;
                }

                .sidebar-brand {
                    padding: 14px 10px;
                    justify-content: center;
                }

                    .sidebar-brand img {
                        width: 36px;
                    }
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    }

    <div class="app-shell">

        <!-- ══ SIDEBAR ══ -->
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <img src="~/image/logo.png" alt="College Logo" />
            </div>

            <nav class="sidebar-nav">
                <a href="@Url.Action("Dashboard", "Admin")"
                   class="sidebar-link @(currentAction == "Dashboard" ? "active" : "")">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Admin/ManageQRCodes"
                   class="sidebar-link @(currentAction == "ManageQRCodes" ? "active" : "")">
                    <i class="fas fa-qrcode"></i>
                    <span>QR Codes</span>
                </a>
                <a href="@Url.Action("Issues", "Admin")"
                   class="sidebar-link @(currentAction == "Issues" ? "active" : "")">
                    <i class="fas fa-list"></i>
                    <span>All Issues</span>
                </a>

                <div class="sidebar-divider"></div>
            </nav>

            <div class="sidebar-footer">
                <a href="@Url.Action("Logout", "Admin")"
                   onclick="return confirmLogout();"
                   class="sidebar-link danger">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- ── Main Area ── -->
        <div class="app-main">
            <div class="app-topbar">
                <a href="@Url.Action("Notifications", "Admin")" class="topbar-notif">
                    <i class="fas fa-bell"></i>
                </a>
                <span class="topbar-welcome">
                    <i class="fas fa-user-circle"></i>
                    Welcome, @Context.Session.GetString("AdminUsername")
                </span>
            </div>

            <div class="app-content">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>

    </div>

    <script>
            function confirmLogout() {
                return confirm('Are you sure you want to logout?');
            }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>