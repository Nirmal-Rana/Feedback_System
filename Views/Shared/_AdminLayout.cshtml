<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: #f4f6fb;
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            /* ── Sidebar ── */
            .app-sidebar {
                width: 240px;
                background: #081547;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                position: sticky;
                top: 0;
                height: 100vh;
            }

            .sidebar-brand {
                padding: 22px 20px;
                display: flex;
                align-items: center;
                gap: 12px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
            }

            .sidebar-brand-icon {
                width: 38px;
                height: 38px;
                background: linear-gradient(135deg, #667eea, #764ba2);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1.05rem;
                flex-shrink: 0;
            }

            .sidebar-brand-text {
                color: white;
                font-weight: 700;
                font-size: 0.96rem;
            }

            .sidebar-nav {
                flex: 1;
                padding: 16px 12px;
                display: flex;
                flex-direction: column;
                gap: 4px;
                overflow-y: auto;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 11px 14px;
                border-radius: 10px;
                color: rgba(255,255,255,0.65);
                text-decoration: none;
                font-size: 0.86rem;
                font-weight: 600;
                transition: all 0.18s;
            }

                .sidebar-link i {
                    font-size: 0.95rem;
                    width: 18px;
                    text-align: center;
                }

                .sidebar-link:hover {
                    background: rgba(255,255,255,0.06);
                    color: white;
                    text-decoration: none;
                }

                .sidebar-link.active {
                    background: linear-gradient(135deg, #667eea, #764ba2);
                    color: white;
                }

            .sidebar-divider {
                height: 1px;
                background: rgba(255,255,255,0.08);
                margin: 10px 6px;
            }

            .sidebar-footer {
                padding: 14px 12px;
                border-top: 1px solid rgba(255,255,255,0.08);
            }

            /* ── Main Content ── */
            .app-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .app-topbar {
                height: 58px;
                background: white;
                border-bottom: 1px solid #eee;
                display: flex;
                align-items: center;
                justify-content: flex-end;
                gap: 18px;
                padding: 0 28px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topbar-notif {
                position: relative;
                color: #555;
                font-size: 1.1rem;
                cursor: pointer;
                text-decoration: none;
            }

                .topbar-notif:hover {
                    color: #667eea;
                }

            .topbar-welcome {
                font-size: 0.86rem;
                color: #666;
                display: flex;
                align-items: center;
                gap: 7px;
            }

                .topbar-welcome i {
                    color: #667eea;
                }

            .app-content {
                flex: 1;
                padding: 24px 28px;
            }

            @@media (max-width: 900px) {
                .app-sidebar {
                    width: 70px;
                }

                .sidebar-brand-text,
                .sidebar-link span {
                    display: none;
                }

                .sidebar-link {
                    justify-content: center;
                }

                    .sidebar-link i {
                        width: auto;
                    }
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    }

    <div class="app-shell">

        <!-- ── Sidebar ── -->
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <div class="sidebar-brand-icon">
                    <img src="~/image/logo.png"
                         alt="Texas College Logo"
                         style="width: 50px; height: 45px; object-fit: contain; background-color: #ffffff; padding: 4px; border-radius: 8px;" />
                </div>
                <span class="sidebar-brand-text">College Admin</span>
            </div>

            <nav class="sidebar-nav">
                <a href="@Url.Action("Dashboard", "Admin")"
                   class="sidebar-link @(currentAction == "Dashboard" ? "active" : "")">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Admin/ManageQRCodes"
                   class="sidebar-link @(currentAction == "ManageQRCodes" ? "active" : "")">
                    <i class="fas fa-qrcode"></i>
                    <span>QR Codes</span>
                </a>
                <a href="@Url.Action("Issues", "Admin")"
                   class="sidebar-link @(currentAction == "Issues" ? "active" : "")">
                    <i class="fas fa-list"></i>
                    <span>All Issues</span>
                </a>

                <div class="sidebar-divider"></div>
            </nav>

            <div class="sidebar-footer">
                <a href="@Url.Action("Logout", "Admin")"
                   onclick="return confirmLogout();"
                   class="sidebar-link" style="color:#ff6b6b;">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- ── Main Area ── -->
        <div class="app-main">
            <div class="app-topbar">
                <a href="@Url.Action("Notifications", "Admin")" class="topbar-notif">
                    <i class="fas fa-bell"></i>
                </a>
                <span class="topbar-welcome">
                    <i class="fas fa-user-circle"></i>
                    Welcome, @Context.Session.GetString("AdminUsername")
                </span>
            </div>

            <div class="app-content">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>

    </div>

    <script>
            function confirmLogout() {
                return confirm('Are you sure you want to logout?');
            }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>